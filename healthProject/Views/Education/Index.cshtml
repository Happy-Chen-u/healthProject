@model List<healthProject.Controllers.HealthEducationModel>
@{
    ViewData["Title"] = "衛教內容管理";
    Layout = null;
    var currentCategory = ViewBag.Category as string ?? "";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();

    var categoryColors = new Dictionary<string, string>
    {
        {"血壓",   "#e53935"},
        {"血糖",   "#e91e63"},
        {"運動",   "#4CAF50"},
        {"水分",   "#1e88e5"},
        {"抽菸",   "#6d4c41"},
        {"嚼檳榔", "#8d6e63"},
        {"綜合",   "#7b1fa2"}
    };

    var categoryEmoji = new Dictionary<string, string>
    {
        {"血壓",   "❤️"},
        {"血糖",   "🩸"},
        {"運動",   "🏃"},
        {"水分",   "💧"},
        {"抽菸",   "🚭"},
        {"嚼檳榔", ""},
        {"綜合",   "📋"}
    };
}
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
    <style>
        body { background: #f0f4f8; font-family: 'Microsoft JhengHei', Arial, sans-serif; }
        .main-container { max-width: 1400px; margin: 2rem auto; padding: 0 1rem; }

        .page-header {
            background: linear-gradient(135deg, #388E3C 0%, #2E7D32 100%);
            color: white; padding: 1.5rem; border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            margin-bottom: 1.5rem;
            display: flex; justify-content: space-between; align-items: center;
        }

        .stats-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
        .stat-card {
            background: white; border-radius: 10px; padding: 0.85rem 1.25rem;
            box-shadow: 0 2px 6px rgba(0,0,0,0.08); flex: 1; min-width: 120px;
            border-left: 4px solid #ccc; text-align: center;
        }
        .stat-card .stat-num { font-size: 1.6rem; font-weight: 700; line-height: 1; }
        .stat-card .stat-label { font-size: 0.78rem; color: #6b7280; margin-top: 0.2rem; }

        .filter-bar {
            background: white;
            border-radius: 10px;
            padding: 1rem 1.25rem 1.2rem 1.25rem;
            box-shadow: 0 2px 6px rgba(0,0,0,0.08);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
            flex-wrap: wrap;
        }

        .category-badge {
    display: inline-block; padding: 0.35rem 0.9rem;
    border-radius: 20px; font-size: 0.8rem; font-weight: 600;
    cursor: pointer; border: 2px solid transparent;
    transition: all 0.2s; white-space: nowrap;
    text-decoration: none; line-height: 1.5;
}
        .category-badge:hover { opacity: 0.85; }
        .category-badge.active { border-color: #333; box-shadow: 0 0 0 2px rgba(0,0,0,0.1); }

        .table-card {
            background: white; border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08); overflow: hidden;
        }

        .edu-table th {
            background: #f8f9fa; font-weight: 600;
            font-size: 0.85rem; color: #374151; border-bottom: 2px solid #e5e7eb;
        }
        .edu-table td { vertical-align: middle; font-size: 0.88rem; }
        .edu-table tr:hover { background: #f9fafb; }

        .content-preview {
            max-width: 320px; overflow: hidden;
            text-overflow: ellipsis; white-space: nowrap;
            color: #6b7280; font-size: 0.82rem;
        }

        .toggle-btn {
            border: none; padding: 0.3rem 0.75rem; border-radius: 20px;
            font-size: 0.78rem; font-weight: 600; cursor: pointer;
            transition: all 0.2s;
        }
        .toggle-btn.active { background: #dcfce7; color: #166534; }
        .toggle-btn.inactive { background: #fee2e2; color: #991b1b; }

        .action-btn {
            border: none; background: none; padding: 0.3rem 0.5rem;
            border-radius: 6px; cursor: pointer; transition: background 0.15s;
            font-size: 1rem;
        }
        .action-btn:hover { background: #f3f4f6; }
        .action-btn.edit:hover { background: #dbeafe; color: #1d4ed8; }
        .action-btn.delete:hover { background: #fee2e2; color: #dc2626; }

        /* 預覽 Modal */
        .preview-bubble {
            background: #f0f0f0; border-radius: 18px 18px 18px 4px;
            padding: 1rem 1.25rem; max-width: 320px;
            font-size: 0.9rem; line-height: 1.6; white-space: pre-wrap;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        .preview-header {
            background: #00b900; color: white; padding: 0.75rem 1rem;
            border-radius: 8px 8px 0 0; font-weight: 600; font-size: 0.9rem;
        }

        .alert-success-custom {
            background: #dcfce7; border: 1px solid #bbf7d0; color: #166534;
            border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1rem;
            display: flex; align-items: center; gap: 0.5rem;
        }
    </style>
</head>
<body>
    <div class="main-container">

        <!-- 頁首 -->
        <div class="page-header">
            <div>
                <h1 style="font-size:1.6rem; font-weight:700; margin:0;">
                    <i class="bi bi-journal-medical"></i> 衛教內容管理
                </h1>
                <div style="font-size:0.85rem; opacity:0.85; margin-top:0.25rem;">
                    管理每日推播給病患的衛教訊息
                </div>
            </div>
            <div class="d-flex gap-2">
                <a href="@Url.Action("Create")" class="btn btn-light btn-sm fw-bold">
                    <i class="bi bi-plus-lg"></i> 新增衛教
                </a>
                <a href="@Url.Action("Index", "Home")" class="btn btn-sm"
                   style="background:rgba(255,255,255,0.2); color:white; border:1px solid rgba(255,255,255,0.4);">
                    <i class="bi bi-arrow-left"></i> 返回主選單
                </a>
            </div>
        </div>

        <!-- 成功訊息 -->
        @if (TempData["Success"] != null)
        {
            <div class="alert-success-custom">
                <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            </div>
        }

        <!-- 統計卡片 -->
        <div class="stats-row" id="statsRow">
            <div class="stat-card" style="border-left-color:#4CAF50;">
                <div class="stat-num" id="totalCount">@Model.Count</div>
                <div class="stat-label">全部</div>
            </div>
        </div>

        <!-- 分類篩選 -->
        <div class="filter-bar">
            <span style="font-size:0.85rem; color:#6b7280; font-weight:600;">篩選分類：</span>
            <a href="@Url.Action("Index")"
               class="category-badge @(currentCategory == "" ? "active" : "")"
               style="background:#e5e7eb; color:#374151;">
                全部（@Model.Count）
            </a>
            @foreach (var cat in categories)
            {
                var color = categoryColors.GetValueOrDefault(cat, "#6b7280");
                var emoji = categoryEmoji.GetValueOrDefault(cat, "📋");
                var count = Model.Count(m => m.Category == cat);
                <a href="@Url.Action("Index", new { category = cat })"
                   class="category-badge @(currentCategory == cat ? "active" : "")"
                   style="background:@color 20; color:@color; border-color:@(currentCategory == cat ? color : "transparent");">
                    @emoji @cat（@count）
                </a>
            }
        </div>

        <!-- 內容列表 -->
        <div class="table-card">
            <div style="padding:1rem 1.25rem; border-bottom:1px solid #e5e7eb; display:flex; justify-content:space-between; align-items:center;">
                <span style="font-weight:600; color:#374151;">
                    @(currentCategory == "" ? "全部衛教內容" : $"{currentCategory} 分類")
                    <span style="color:#6b7280; font-weight:400; font-size:0.85rem;">（共 @Model.Count 則）</span>
                </span>
            </div>

            @if (!Model.Any())
            {
                <div style="padding:3rem; text-align:center; color:#9ca3af;">
                    <i class="bi bi-journal-x" style="font-size:2.5rem;"></i>
                    <p class="mt-2">目前沒有衛教內容，點擊「新增衛教」開始建立</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table edu-table mb-0">
                        <thead>
                            <tr>
                                <th style="width:60px;">排序</th>
                                <th style="width:90px;">分類</th>
                                <th style="width:200px;">標題</th>
                                <th>內容預覽</th>
                                <th style="width:90px; text-align:center;">狀態</th>
                                <th style="width:120px; text-align:center;">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var color = categoryColors.GetValueOrDefault(item.Category, "#6b7280");
                                var emoji = categoryEmoji.GetValueOrDefault(item.Category, "📋");
                                <tr id="row-@item.Id">
                                    <td style="color:#9ca3af; font-size:0.8rem; text-align:center;">@item.SortOrder</td>
                                    <td>
                                        <span style="background:@(color)22; color:@color; padding:0.2rem 0.6rem; border-radius:20px; font-size:0.78rem; font-weight:600;">
                                            @emoji @item.Category
                                        </span>
                                    </td>
                                    <td style="font-weight:500;">@item.Title</td>
                                    <td>
                                        <div class="content-preview" title="@item.Content">@item.Content</div>
                                    </td>
                                    <td style="text-align:center;">
                                        <button class="toggle-btn @(item.IsActive ? "active" : "inactive")"
                                                id="toggle-@item.Id"
                                                onclick="toggleActive(@item.Id)">
                                            @(item.IsActive ? "✓ 啟用" : "✗ 停用")
                                        </button>
                                    </td>
                                    <td style="text-align:center;">
                                        <button class="action-btn" title="預覽 LINE 訊息效果"
                                                onclick="previewEducation(@item.Id, '@Html.Raw(item.Category)', '@Html.Raw(item.Title)', '@Html.Raw(item.Content.Replace("'", "\\'").Replace("\n", "\\n"))')">
                                            👁️
                                        </button>
                                        <a href="@Url.Action("Edit", new { id = item.Id })"
                                           class="action-btn edit" title="編輯">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button class="action-btn delete" title="刪除"
                                                onclick="deleteEducation(@item.Id, '@Html.Raw(item.Title)')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- 預覽 Modal -->
    <div class="modal fade" id="previewModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content" style="border-radius:12px; overflow:hidden;">
                <div class="preview-header">
                    <i class="bi bi-chat-dots-fill"></i> LINE 推播預覽
                </div>
                <div class="modal-body" style="background:#e0e0e0; padding:1.5rem; min-height:200px;">
                    <div style="font-size:0.75rem; color:#666; margin-bottom:0.5rem; text-align:center;">
                        代謝症候群管理系統
                    </div>
                    <div class="preview-bubble" id="previewContent"></div>
                </div>
                <div class="modal-footer" style="border:none; padding:0.75rem 1rem;">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">關閉</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // 分類顏色對照
        const categoryColors = {
            '血壓': '#e53935', '血糖': '#e91e63', '運動': '#4CAF50',
            '水分': '#1e88e5', '抽菸': '#6d4c41', '嚼檳榔': '#8d6e63', '綜合': '#7b1fa2'
        };
        const categoryEmoji = {
            '血壓': '❤️', '血糖': '🩸', '運動': '🏃',
            '水分': '💧', '抽菸': '🚭', '嚼檳榔': '🌿', '綜合': '📋'
        };

        // 啟用/停用
        async function toggleActive(id) {
            try {
                const res = await fetch(`/Education/ToggleActive`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
                    body: JSON.stringify(id)
                });
                const result = await res.json();
                if (result.success) {
                    const btn = document.getElementById(`toggle-${id}`);
                    if (result.isActive) {
                        btn.className = 'toggle-btn active';
                        btn.textContent = '✓ 啟用';
                    } else {
                        btn.className = 'toggle-btn inactive';
                        btn.textContent = '✗ 停用';
                    }
                }
            } catch (e) { alert('操作失敗，請稍後再試'); }
        }

        // 刪除
        async function deleteEducation(id, title) {
            if (!confirm(`確定要刪除「${title}」嗎？\n\n此操作無法復原，相關推播紀錄也會一併刪除。`)) return;
            try {
                const res = await fetch(`/Education/Delete`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
                    body: JSON.stringify(id)
                });
                const result = await res.json();
                if (result.success) {
                    const row = document.getElementById(`row-${id}`);
                    row.style.transition = 'opacity 0.3s';
                    row.style.opacity = '0';
                    setTimeout(() => row.remove(), 300);
                } else {
                    alert('刪除失敗，請稍後再試');
                }
            } catch (e) { alert('刪除失敗，請稍後再試'); }
        }

        // 預覽 LINE 訊息
        function previewEducation(id, category, title, content) {
            const emoji = categoryEmoji[category] || '📋';
            const text = `${emoji} 今日健康衛教\n━━━━━━━━━━━━━━━\n【${category}】${title}\n\n${content.replace(/\\n/g, '\n')}`;
            document.getElementById('previewContent').textContent = text;
            new bootstrap.Modal(document.getElementById('previewModal')).show();
        }

        // 取得 Anti-Forgery Token
        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        // 載入統計
        async function loadStats() {
            try {
                const res = await fetch('/Education/Stats');
                const stats = await res.json();
                const row = document.getElementById('statsRow');
                stats.forEach(s => {
                    const color = categoryColors[s.category] || '#6b7280';
                    const emoji = categoryEmoji[s.category] || '📋';
                    const card = document.createElement('div');
                    card.className = 'stat-card';
                    card.style.borderLeftColor = color;
                    card.innerHTML = `
                        <div class="stat-num" style="color:${color}">${s.active}</div>
                        <div class="stat-label">${emoji} ${s.category}</div>
                        <div style="font-size:0.7rem; color:#9ca3af;">共 ${s.total} 則</div>
                    `;
                    row.appendChild(card);
                });
            } catch (e) { console.error('載入統計失敗', e); }
        }

        document.addEventListener('DOMContentLoaded', loadStats);
    </script>

    @Html.AntiForgeryToken()
</body>
</html>
