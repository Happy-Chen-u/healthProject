@model healthProject.Controllers.HealthEducationModel
@{
    var isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "編輯衛教內容" : "新增衛教內容";
    Layout = null;
    var categories = ViewBag.Categories as List<string> ?? new List<string>();

    var categoryEmoji = new Dictionary<string, string>
    {
        {"血壓","❤️"}, {"血糖","🩸"}, {"運動","🏃"},
        {"水分","💧"}, {"抽菸","🚭"}, {"嚼檳榔","🌿"}, {"綜合","📋"}
    };
}
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
    <style>
        body { background: #f0f4f8; font-family: 'Microsoft JhengHei', Arial, sans-serif; }
        .main-container { max-width: 860px; margin: 2rem auto; padding: 0 1rem; }

        .page-header {
            background: linear-gradient(135deg, #388E3C 0%, #2E7D32 100%);
            color: white; padding: 1.25rem 1.5rem; border-radius: 10px;
            margin-bottom: 1.5rem; display: flex;
            justify-content: space-between; align-items: center;
        }

        .form-card {
            background: white; border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08); padding: 2rem;
        }

        .form-label { font-weight: 600; color: #374151; font-size: 0.9rem; }

        .form-control, .form-select {
            border: 1.5px solid #e5e7eb; border-radius: 8px;
            font-size: 0.9rem; transition: border-color 0.2s;
        }
        .form-control:focus, .form-select:focus {
            border-color: #4CAF50; box-shadow: 0 0 0 3px rgba(76,175,80,0.15);
        }

        textarea.form-control { min-height: 180px; resize: vertical; line-height: 1.7; }

        .char-count { font-size: 0.75rem; color: #9ca3af; text-align: right; margin-top: 0.25rem; }

        /* LINE 預覽面板 */
        .preview-panel {
            background: #e0e0e0; border-radius: 10px; padding: 1rem;
            position: sticky; top: 1rem;
        }
        .preview-panel-header {
            background: #00b900; color: white; border-radius: 8px 8px 0 0;
            padding: 0.5rem 0.85rem; font-size: 0.8rem; font-weight: 600;
            margin: -1rem -1rem 0.85rem -1rem;
            border-radius: 8px 8px 0 0;
        }
        .preview-bubble {
            background: white; border-radius: 4px 18px 18px 18px;
            padding: 0.85rem 1rem; font-size: 0.85rem;
            line-height: 1.7; white-space: pre-wrap;
            box-shadow: 0 1px 4px rgba(0,0,0,0.1);
            min-height: 80px; color: #1a1a1a;
        }

        .btn-save {
            background: linear-gradient(135deg, #4CAF50, #388E3C);
            color: white; border: none; padding: 0.65rem 2rem;
            border-radius: 8px; font-weight: 600; font-size: 0.95rem;
            transition: opacity 0.2s;
        }
        .btn-save:hover { opacity: 0.9; color: white; }

        .category-selector { display: flex; flex-wrap: wrap; gap: 0.5rem; }
        .category-option {
            padding: 0.4rem 0.9rem; border-radius: 20px; border: 2px solid #e5e7eb;
            cursor: pointer; font-size: 0.85rem; transition: all 0.15s;
            background: white;
        }
        .category-option:hover { border-color: #4CAF50; }
        .category-option.selected { border-color: #4CAF50; background: #f0fdf4; font-weight: 600; }
    </style>
</head>
<body>
    <div class="main-container">

        <!-- 頁首 -->
        <div class="page-header">
            <h1 style="font-size:1.4rem; font-weight:700; margin:0;">
                <i class="bi bi-@(isEdit ? "pencil-square" : "plus-circle")"></i>
                @(isEdit ? "編輯衛教內容" : "新增衛教內容")
            </h1>
            <a href="@Url.Action("Index")" class="btn btn-sm"
               style="background:rgba(255,255,255,0.2); color:white; border:1px solid rgba(255,255,255,0.4);">
                <i class="bi bi-arrow-left"></i> 返回列表
            </a>
        </div>

        <div class="row g-3">
            <!-- 左側：表單 -->
            <div class="col-lg-7">
                <div class="form-card">
                    @using (Html.BeginForm(isEdit ? "Edit" : "Create", "Education", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        if (isEdit)
                        {
                            <input type="hidden" name="Id" value="@Model.Id" />
                        }

                        <!-- 分類 -->
                        <div class="mb-4">
                            <label class="form-label">分類 <span style="color:#dc2626;">*</span></label>
                            <input type="hidden" id="categoryInput" name="Category" value="@Model.Category" />
                            <div class="category-selector" id="categorySelector">
                                @foreach (var cat in new[] { "血壓", "血糖", "運動", "水分", "抽菸", "嚼檳榔", "綜合" })
                                {
                                    var emoji = categoryEmoji.GetValueOrDefault(cat, "📋");
                                    <div class="category-option @(Model.Category == cat ? "selected" : "")"
                                         onclick="selectCategory('@cat')">
                                        @emoji @cat
                                    </div>
                                }
                            </div>
                            @Html.ValidationMessage("Category", new { @class = "text-danger small" })
                        </div>

                        <!-- 標題 -->
                        <div class="mb-3">
                            <label class="form-label">標題 <span style="color:#dc2626;">*</span></label>
                            <input type="text" name="Title" id="titleInput"
                                   class="form-control" maxlength="100"
                                   value="@Model.Title" placeholder="例如：量血壓的正確姿勢"
                                   oninput="updatePreview()" />
                            <div class="char-count"><span id="titleCount">@(Model.Title?.Length ?? 0)</span> / 100</div>
                            @Html.ValidationMessage("Title", new { @class = "text-danger small" })
                        </div>

                        <!-- 內容 -->
                        <div class="mb-3">
                            <label class="form-label">內容 <span style="color:#dc2626;">*</span></label>
                            <textarea name="Content" id="contentInput"
                                      class="form-control" maxlength="600"
                                      placeholder="輸入推播給病患的衛教內容..."
                                      oninput="updatePreview()">@Model.Content</textarea>
                            <div class="char-count"><span id="contentCount">@(Model.Content?.Length ?? 0)</span> / 600</div>
                            @Html.ValidationMessage("Content", new { @class = "text-danger small" })
                        </div>

                        <!-- 排序 + 狀態 -->
                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <label class="form-label">狀態</label>
                                <div class="mt-2">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" name="IsActive"
                                               id="isActiveCheck" value="true"
                                        @(Model.IsActive ? "checked" : "") />
                                        <label class="form-check-label" for="isActiveCheck"
                                               style="font-size:0.88rem;">
                                            啟用（會納入推播輪流）
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-save">
                                <i class="bi bi-check-lg"></i> @(isEdit ? "儲存修改" : "新增內容")
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">取消</a>
                        </div>
                    }
                </div>
            </div>

            <!-- 右側：即時預覽 -->
            <div class="col-lg-5">
                <div class="preview-panel">
                    <div class="preview-panel-header">
                        <i class="bi bi-chat-dots-fill"></i> LINE 推播即時預覽
                    </div>
                    <div style="font-size:0.72rem; color:#666; text-align:center; margin-bottom:0.75rem;">
                        病患收到的訊息效果
                    </div>
                    <div class="preview-bubble" id="previewBubble">
                        請填寫分類、標題與內容以預覽...
                    </div>
                    <div style="font-size:0.72rem; color:#888; text-align:right; margin-top:0.5rem;">
                        LINE 訊息 · 代謝症候群管理系統
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const categoryEmoji = {
            '血壓': '❤️', '血糖': '🩸', '運動': '🏃',
            '水分': '💧', '抽菸': '🚭', '嚼檳榔': '🌿', '綜合': '📋'
        };

        function selectCategory(cat) {
            document.getElementById('categoryInput').value = cat;
            document.querySelectorAll('.category-option').forEach(el => {
                el.classList.toggle('selected', el.textContent.trim().includes(cat));
            });
            updatePreview();
        }

        function updatePreview() {
            const category = document.getElementById('categoryInput').value;
            const title = document.getElementById('titleInput').value;
            const content = document.getElementById('contentInput').value;

            const titleLen = title.length;
            const contentLen = content.length;
            document.getElementById('titleCount').textContent = titleLen;
            document.getElementById('contentCount').textContent = contentLen;

            const bubble = document.getElementById('previewBubble');
            if (!category && !title && !content) {
                bubble.textContent = '請填寫分類、標題與內容以預覽...';
                bubble.style.color = '#9ca3af';
                return;
            }

            const emoji = categoryEmoji[category] || '📋';
            bubble.style.color = '#1a1a1a';
            bubble.textContent = `${emoji} 今日健康衛教\n━━━━━━━━━━━━━━━\n【${category || '（分類）'}】${title || '（標題）'}\n\n${content || '（內容）'}`;
        }

        // 初始化
        document.addEventListener('DOMContentLoaded', updatePreview);
    </script>
</body>
</html>
