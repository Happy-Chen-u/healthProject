@{
    ViewData["Title"] = "我的健康分析";
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
    <style>
        body {
            background: #f0f4f8;
            font-family: 'Microsoft JhengHei', Arial, sans-serif;
        }

        .main-container {
            max-width: 1400px;
            margin: 2rem auto;
            padding: 0 1rem;
        }

        .page-header {
            background: linear-gradient(135deg, #66BB6A 0%, #4CAF50 100%);
            color: white;
            padding: 1.5rem;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            margin-bottom: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .page-title {
            font-size: 1.8rem;
            font-weight: 600;
            margin: 0;
            color: white;
        }

        .btn-back {
            background: rgba(255,255,255,0.2);
            color: white;
            border: 1px solid rgba(255,255,255,0.5);
            padding: 0.5rem 1.5rem;
            border-radius: 5px;
            text-decoration: none;
        }

            .btn-back:hover {
                background: rgba(255,255,255,0.35);
                color: white;
            }

        .nav-tabs {
            border-bottom: 2px solid #5a9;
        }

            .nav-tabs .nav-link {
                color: #666;
                font-weight: 500;
                border: none;
                padding: 0.75rem 1.5rem;
            }

                .nav-tabs .nav-link.active {
                    background: #ffc107;
                    color: #333;
                    border-radius: 8px 8px 0 0;
                    font-weight: 600;
                }

        .table-card {
            background: white;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            padding: 1.5rem;
        }

        .loading {
            display: none;
            text-align: center;
            padding: 3rem;
        }

        .summary-table th {
            background: #ffc107;
            color: #333;
            font-weight: 600;
            text-align: center;
        }

        .summary-table td {
            font-size: 1.5rem;
            font-weight: 700;
            text-align: center;
        }

        .abnormal {
            color: #dc3545;
        }

        .warning {
            color: #fd7e14;
        }

        .badge {
            font-size: 0.9rem;
            padding: 0.4rem 0.8rem;
        }

        .patient-info-section {
            background: white;
            padding: 1rem 1.5rem;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            margin-bottom: 1rem;
            border-left: 4px solid #4CAF50;
        }
    </style>
</head>
<body>
    <div class="main-container">
        <!-- 頁首 -->
        <div class="page-header">
            <h1 class="page-title"><i class="bi bi-graph-up"></i> 我的健康分析</h1>
            <div class="d-flex gap-2">
                <button class="btn btn-sm" onclick="testWeeklyReport()"
                        style="background:rgba(255,255,255,0.2); color:white; border:1px solid rgba(255,255,255,0.5);">
                    <i class="bi bi-send"></i> 測試傳送週報到 LINE
                </button>
                <a href="@Url.Action("Index", "Home")" class="btn-back">
                    <i class="bi bi-arrow-left"></i> 返回主選單
                </a>
            </div>
        </div>

        <!-- 分頁標籤 -->
        <ul class="nav nav-tabs mb-3" id="reportTypeTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="daily-tab" data-bs-toggle="tab"
                        data-bs-target="#daily" type="button" role="tab" onclick="selectReportType(0)">
                    每日
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="weekly-tab" data-bs-toggle="tab"
                        data-bs-target="#weekly" type="button" role="tab" onclick="selectReportType(1)">
                    每週
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="monthly-tab" data-bs-toggle="tab"
                        data-bs-target="#monthly" type="button" role="tab" onclick="selectReportType(2)">
                    每月
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="yearly-tab" data-bs-toggle="tab"
                        data-bs-target="#yearly" type="button" role="tab" onclick="selectReportType(3)">
                    每年
                </button>
            </li>
        </ul>

        <!-- 分頁內容 (日期選擇 + 搜尋按鈕) -->
        <div class="tab-content table-card" id="reportTypeTabContent">
            <!-- 每日 -->
            <div class="tab-pane fade" id="daily" role="tabpanel">
                <div class="d-flex align-items-end gap-3 mb-2">
                    <div>
                        <label class="form-label fw-bold">選擇日期</label>
                        <input type="date" class="form-control" id="dailyDate">
                    </div>
                    <div class="d-flex gap-2 mb-1">
                        <button class="btn btn-primary" onclick="searchReport()"><i class="bi bi-search"></i> 搜尋</button>
                        <button class="btn btn-secondary" onclick="clearResults()"><i class="bi bi-arrow-counterclockwise"></i> 清除</button>
                    </div>
                </div>
            </div>

            <!-- 每週 -->
            <div class="tab-pane fade show active" id="weekly" role="tabpanel">
                <div class="d-flex align-items-end gap-3 mb-2">
                    <div>
                        <label class="form-label fw-bold">週開始日期</label>
                        <input type="date" class="form-control" id="weeklyStartDate">
                    </div>
                    <div class="d-flex gap-2 mb-1">
                        <button class="btn btn-primary" onclick="searchReport()"><i class="bi bi-search"></i> 搜尋</button>
                        <button class="btn btn-secondary" onclick="clearResults()"><i class="bi bi-arrow-counterclockwise"></i> 清除</button>
                    </div>
                </div>
            </div>

            <!-- 每月 -->
            <div class="tab-pane fade" id="monthly" role="tabpanel">
                <div class="d-flex align-items-end gap-3 mb-2">
                    <div>
                        <label class="form-label fw-bold">選擇年月</label>
                        <input type="month" class="form-control" id="monthlyDate">
                    </div>
                    <div class="d-flex gap-2 mb-1">
                        <button class="btn btn-primary" onclick="searchReport()"><i class="bi bi-search"></i> 搜尋</button>
                        <button class="btn btn-secondary" onclick="clearResults()"><i class="bi bi-arrow-counterclockwise"></i> 清除</button>
                    </div>
                </div>
            </div>

            <!-- 每年 -->
            <div class="tab-pane fade" id="yearly" role="tabpanel">
                <div class="d-flex align-items-end gap-3 mb-2">
                    <div>
                        <label class="form-label fw-bold">選擇年份</label>
                        <select class="form-select" id="yearlyDate"></select>
                    </div>
                    <div class="d-flex gap-2 mb-1">
                        <button class="btn btn-primary" onclick="searchReport()"><i class="bi bi-search"></i> 搜尋</button>
                        <button class="btn btn-secondary" onclick="clearResults()"><i class="bi bi-arrow-counterclockwise"></i> 清除</button>
                    </div>
                </div>
            </div>

            <!-- 載入中 -->
            <div id="loadingDiv" class="loading">
                <div class="spinner-border text-success" role="status">
                    <span class="visually-hidden">載入中...</span>
                </div>
                <p class="mt-3 text-success fw-bold">正在產生報表...</p>
            </div>

            <!-- 病患基本資訊 (登入者自己) -->
            <div id="patientInfo" class="patient-info-section" style="display:none;">
                <div class="d-flex align-items-center gap-4 flex-wrap">
                    <span><i class="bi bi-person-circle me-1 text-success"></i><strong>姓名：</strong><span id="patientName"></span></span>
                    <span><strong>性別：</strong><span id="patientGender">-</span></span>
                    <span><strong>生日：</strong><span id="patientBirth">-</span></span>
                </div>
            </div>

            <!-- 報表內容 -->
            <div id="reportContent" style="display:none;">
                <!-- 每日報表表格 -->
                <div id="dailyTable" style="display:none;">
                    <div class="table-card mt-3">
                        <div id="dailyNav" style="display:flex; align-items:center; justify-content:center; gap:1rem; margin-bottom:1rem;">
                            <button onclick="navigateDaily(-1)" style="background:#4CAF50; color:white; border:none; border-radius:50%; width:36px; height:36px; font-size:1.2rem; cursor:pointer;">‹</button>
                            <span id="dailyNavDate" style="font-weight:600; font-size:1.1rem; min-width:120px; text-align:center;"></span>
                            <button onclick="navigateDaily(1)" style="background:#4CAF50; color:white; border:none; border-radius:50%; width:36px; height:36px; font-size:1.2rem; cursor:pointer;">›</button>
                        </div>
                        <h5 class="mb-3"><i class="bi bi-calendar-day"></i> 當日健康數據</h5>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:30%;">項目</th>
                                        <th style="width:25%; text-align:center;">數值</th>
                                        <th style="width:25%; text-align:center;">標準值</th>
                                        <th style="width:20%; text-align:center;">狀態</th>
                                    </tr>
                                </thead>
                                <tbody id="dailyTableBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 統計摘要 (週/月/年) -->
                <div id="summarySection" style="display:none;">
                    <div class="table-card mb-3 mt-3">
                        <h5 class="mb-3"><i class="bi bi-bar-chart"></i> 統計摘要</h5>
                        <div class="table-responsive">
                            <table class="table summary-table">
                                <thead>
                                    <tr>
                                        <th>總天數</th>
                                        <th>血壓異常天數</th>
                                        <th>血糖異常天數</th>
                                        <th>水分不足天數</th>
                                        <th>運動時間不足天數</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td id="totalDays">0</td>
                                        <td id="highBPDays" class="abnormal">0</td>
                                        <td id="highBSDays" class="abnormal">0</td>
                                        <td id="lowWaterDays" class="warning">0</td>
                                        <td id="lowExerciseDays" class="warning">0</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="table-responsive mt-4">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>項目</th>
                                        <th class="text-center">平均值</th>
                                        <th class="text-center">標準值</th>
                                        <th class="text-center">狀態</th>
                                    </tr>
                                </thead>
                                <tbody id="avgTable"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 圖表區域 -->
                <div id="chartsSection" style="display:none;">
                    <div class="table-card mb-3">
                        <h5 class="mb-3"><i class="bi bi-heart-pulse"></i> 血壓趨勢</h5>
                        <canvas id="bpChart" style="max-height:300px;"></canvas>
                        <input type="range" id="bpSlider" min="0" max="100" value="0"
                               style="width:100%; margin-top:0.5rem;" oninput="slideChart('bp', this.value)">
                        <div style="text-align:right; margin-top:0.25rem;">
                            <button onclick="resetZoom('bp')" class="btn btn-sm btn-outline-secondary">🔄 重置</button>
                        </div>
                    </div>

                    <div class="table-card mb-3">
                        <h5 class="mb-3"><i class="bi bi-droplet"></i> 血糖趨勢</h5>
                        <canvas id="bsChart" style="max-height:300px;"></canvas>
                        <input type="range" id="bsSlider" min="0" max="100" value="0"
                               style="width:100%; margin-top:0.5rem;" oninput="slideChart('bs', this.value)">
                        <div style="text-align:right; margin-top:0.5rem;">
                            <button onclick="resetZoom('bs')" class="btn btn-sm btn-outline-secondary">🔄 重置</button>
                        </div>
                    </div>

                    <div class="table-card mb-3">
                        <h5 class="mb-3"><i class="bi bi-cup-straw"></i> 飲水量趨勢</h5>
                        <canvas id="waterChart" style="max-height:300px;"></canvas>
                        <input type="range" id="waterSlider" min="0" max="100" value="0"
                               style="width:100%; margin-top:0.5rem;" oninput="slideChart('water', this.value)">
                        <div style="text-align:right; margin-top:0.5rem;">
                            <button onclick="resetZoom('water')" class="btn btn-sm btn-outline-secondary">🔄 重置</button>
                        </div>
                    </div>

                    <div class="table-card mb-3">
                        <h5 class="mb-3"><i class="bi bi-person-walking"></i> 運動時間趨勢</h5>
                        <canvas id="exerciseChart" style="max-height:300px;"></canvas>
                        <input type="range" id="exerciseSlider" min="0" max="100" value="0"
                               style="width:100%; margin-top:0.5rem;" oninput="slideChart('exercise', this.value)">
                        <div style="text-align:right; margin-top:0.5rem;">
                            <button onclick="resetZoom('exercise')" class="btn btn-sm btn-outline-secondary">🔄 重置</button>
                        </div>
                    </div>

                    <div class="table-card mb-3">
                        <h5 class="mb-3"><i class="bi bi-x-circle"></i> 抽菸趨勢</h5>
                        <canvas id="cigaretteChart" style="max-height:300px;"></canvas>
                        <input type="range" id="cigaretteSlider" min="0" max="100" value="0"
                               style="width:100%; margin-top:0.5rem;" oninput="slideChart('cigarette', this.value)">
                        <div style="text-align:right; margin-top:0.5rem;">
                            <button onclick="resetZoom('cigarette')" class="btn btn-sm btn-outline-secondary">🔄 重置</button>
                        </div>
                    </div>

                    <div class="table-card mb-3">
                        <h5 class="mb-3"><i class="bi bi-flower1"></i> 檳榔趨勢</h5>
                        <canvas id="betelNutChart" style="max-height:300px;"></canvas>
                        <input type="range" id="betelNutSlider" min="0" max="100" value="0"
                               style="width:100%; margin-top:0.5rem;" oninput="slideChart('betelNut', this.value)">
                        <div style="text-align:right; margin-top:0.5rem;">
                            <button onclick="resetZoom('betelNut')" class="btn btn-sm btn-outline-secondary">🔄 重置</button>
                        </div>
                    </div>

                    <div class="table-card mb-3">
                        <h5 class="mb-3"><i class="bi bi-egg-fried"></i> 三餐記錄</h5>
                        <div id="mealTable"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/hammerjs@2.0.8/hammer.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.1/dist/chartjs-plugin-zoom.min.js"></script>
    <script>
        let currentReportType = 1;
        let currentReport = null;
        let charts = {};
        let currentDailyDate = null;
        let chartInitRanges = {};

        document.addEventListener('DOMContentLoaded', function () {
            initializeYearSelect();
            setDefaultDates();
        });

        function initializeYearSelect() {
            const yearSelect = document.getElementById('yearlyDate');
            const currentYear = new Date().getFullYear();
            for (let year = currentYear; year >= currentYear - 10; year--) {
                const option = document.createElement('option');
                option.value = year;
                option.textContent = year + ' 年';
                yearSelect.appendChild(option);
            }
        }

        function setDefaultDates() {
            const today = new Date();
            document.getElementById('dailyDate').valueAsDate = today;

            const lastMonday = new Date(today);
            lastMonday.setDate(today.getDate() - today.getDay() - 6);
            document.getElementById('weeklyStartDate').valueAsDate = lastMonday;

            document.getElementById('monthlyDate').value = today.toISOString().substr(0, 7);
        }

        function selectReportType(type) {
            currentReportType = type;
        }

        function clearResults() {
            document.getElementById('patientInfo').style.display = 'none';
            document.getElementById('reportContent').style.display = 'none';
            document.getElementById('loadingDiv').style.display = 'none';
            setDefaultDates();
            currentReport = null;
        }

        // 每日導航 (上一天 / 下一天)
        async function navigateDaily(direction) {
            const current = new Date(currentDailyDate);
            current.setDate(current.getDate() + direction);
            const newDate = current.toISOString().substr(0, 10);

            currentDailyDate = newDate;
            document.getElementById('dailyDate').value = newDate;

            const d = new Date(newDate);
            document.getElementById('dailyNavDate').textContent =
                `${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}`;

            document.getElementById('loadingDiv').style.display = 'block';
            document.getElementById('reportContent').style.display = 'none';

            try {
                const response = await fetch('/Analysis/GetPatientReport', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        reportType: 0,
                        startDate: newDate,
                        endDate: newDate
                    })
                });
                const result = await response.json();
                if (result.success) {
                    currentReport = result.data;
                    displayReport(result.data);
                } else {
                    document.getElementById('reportContent').style.display = 'block';
                    document.getElementById('dailyTable').style.display = 'block';
                    document.getElementById('summarySection').style.display = 'none';
                    document.getElementById('chartsSection').style.display = 'none';
                    document.getElementById('dailyTableBody').innerHTML =
                        '<tr><td colspan="4" class="text-center text-muted py-4">該日期無健康數據</td></tr>';
                }
            } catch (error) {
                console.error('切換日期錯誤:', error);
            } finally {
                document.getElementById('loadingDiv').style.display = 'none';
            }
        }

        // 搜尋報表 (病患不需要輸入身分證)
        async function searchReport() {
            let startDate, endDate;

            switch (currentReportType) {
                case 0: {
                    const daily = document.getElementById('dailyDate').value;
                    if (!daily) { alert('請選擇日期'); return; }
                    startDate = daily; endDate = daily;
                    currentDailyDate = daily;
                    break;
                }
                case 1: {
                    const weekStart = document.getElementById('weeklyStartDate').value;
                    if (!weekStart) { alert('請選擇週開始日期'); return; }
                    startDate = weekStart;
                    const weekEnd = new Date(weekStart);
                    weekEnd.setDate(weekEnd.getDate() + 6);
                    endDate = weekEnd.toISOString().substr(0, 10);
                    break;
                }
                case 2: {
                    const monthly = document.getElementById('monthlyDate').value;
                    if (!monthly) { alert('請選擇年月'); return; }
                    const [year, month] = monthly.split('-');
                    startDate = `${year}-${month}-01`;
                    const lastDay = new Date(year, month, 0).getDate();
                    endDate = `${year}-${month}-${String(lastDay).padStart(2, '0')}`;
                    break;
                }
                case 3: {
                    const yearVal = document.getElementById('yearlyDate').value;
                    startDate = `${yearVal}-01-01`;
                    endDate = `${yearVal}-12-31`;
                    break;
                }
            }

            document.getElementById('loadingDiv').style.display = 'block';
            document.getElementById('patientInfo').style.display = 'none';
            document.getElementById('reportContent').style.display = 'none';

            try {
                const response = await fetch('/Analysis/GetPatientReport', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ reportType: currentReportType, startDate, endDate })
                });
                const result = await response.json();

                if (result.success) {
                    currentReport = result.data;
                    displayPatientInfo(result.data);
                    displayReport(result.data);
                } else {
                    alert(result.message || '查詢失敗');
                }
            } catch (error) {
                console.error('查詢錯誤:', error);
                alert('系統錯誤，請稍後再試');
            } finally {
                document.getElementById('loadingDiv').style.display = 'none';
            }
        }

        function displayPatientInfo(data) {
            document.getElementById('patientInfo').style.display = 'block';
            document.getElementById('patientName').textContent = data.patientName;
            document.getElementById('patientGender').textContent = data.patientGender || '未記錄';
            if (data.patientBirthDate) {
                const d = new Date(data.patientBirthDate);
                document.getElementById('patientBirth').textContent =
                    `${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}`;
            } else {
                document.getElementById('patientBirth').textContent = '未記錄';
            }
        }

        function displayReport(data) {
            document.getElementById('reportContent').style.display = 'block';

            if (currentReportType === 0) {
                document.getElementById('dailyTable').style.display = 'block';
                document.getElementById('summarySection').style.display = 'none';
                document.getElementById('chartsSection').style.display = 'none';
                if (currentDailyDate) {
                    const d = new Date(currentDailyDate);
                    document.getElementById('dailyNavDate').textContent =
                        `${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}`;
                }
                displayDailyTable(data);
            } else {
                document.getElementById('dailyTable').style.display = 'none';
                document.getElementById('summarySection').style.display = 'block';
                document.getElementById('chartsSection').style.display = 'block';
                displayChartReport(data);
            }
        }

        function displayDailyTable(data) {
            const tbody = document.getElementById('dailyTableBody');
            tbody.innerHTML = '';

            const stats = data.statistics;
            const goals = data.goals || {};
            const records = data.records;
            const record = records && records.length > 0 ? records[0] : null;

            const sysBPTarget = goals.systolicBPTarget ?? 130;
            const diaBPTarget = goals.diastolicBPTarget ?? 80;
            const glucoseTarget = goals.fastingGlucoseTarget ?? 100;
            const waterTarget = goals.waterTarget ?? 2000;

            const badge = (text, type) => {
                const colors = {
                    success: 'background:#4CAF50; color:#fff;',
                    danger: 'background:#F44336; color:#fff;',
                    warning: 'background:#FF9800; color:#fff;'
                };
                return `<span style="display:inline-block; padding:0.35rem 1rem; border-radius:20px; font-size:0.85rem; font-weight:600; ${colors[type]}">${text}</span>`;
            };

            const rows = [];

            if (stats.avgSystolicBP !== null && stats.avgDiastolicBP !== null) {
                const isAbnormal = stats.avgSystolicBP > sysBPTarget || stats.avgDiastolicBP > diaBPTarget;
                rows.push({
                    name: '❤️ 血壓',
                    value: `${stats.avgSystolicBP.toFixed(0)} / ${stats.avgDiastolicBP.toFixed(0)} mmHg`,
                    standard: `≤ ${sysBPTarget}/${diaBPTarget} mmHg`,
                    status: isAbnormal ? badge('⚠️ 偏高', 'danger') : badge('✓ 正常', 'success'),
                    isAbnormal
                });
            }

            if (stats.avgBloodSugar !== null) {
                const isAbnormal = stats.avgBloodSugar > glucoseTarget;
                rows.push({
                    name: '🩸 血糖',
                    value: `${stats.avgBloodSugar.toFixed(1)} mg/dL`,
                    standard: `≤ ${glucoseTarget} mg/dL`,
                    status: isAbnormal ? badge('⚠️ 偏高', 'danger') : badge('✓ 正常', 'success'),
                    isAbnormal
                });
            }

            if (stats.avgWaterIntake !== null) {
                const isAbnormal = stats.avgWaterIntake < waterTarget;
                rows.push({
                    name: '💧 飲水量',
                    value: `${stats.avgWaterIntake.toFixed(0)} ml`,
                    standard: `≥ ${waterTarget} ml`,
                    status: isAbnormal ? badge('⚠️ 不足', 'danger') : badge('✓ 充足', 'success'),
                    isAbnormal
                });
            }

            if (stats.avgExerciseDuration !== null) {
                const isAbnormal = stats.avgExerciseDuration < 30;
                rows.push({
                    name: '🏃 運動時間',
                    value: `${stats.avgExerciseDuration.toFixed(0)} 分鐘`,
                    standard: '≥ 30 分鐘',
                    status: isAbnormal ? badge('⚠️ 不足', 'danger') : badge('✓ 充足', 'success'),
                    isAbnormal
                });
            }

            if (stats.avgCigarettes !== null && stats.avgCigarettes > 0) {
                rows.push({
                    name: '🚬 抽菸', value: `${stats.avgCigarettes.toFixed(0)} 支`,
                    standard: '0 支', status: badge('⚠️ 建議戒菸', 'danger'), isAbnormal: true
                });
            }

            if (stats.avgBetelNut !== null && stats.avgBetelNut > 0) {
                rows.push({
                    name: '🌿 檳榔', value: `${stats.avgBetelNut.toFixed(0)} 次`,
                    standard: '0 次', status: badge('⚠️ 建議戒除', 'danger'), isAbnormal: true
                });
            }

            rows.forEach(row => {
                const tr = document.createElement('tr');
                if (row.isAbnormal) tr.style.background = '#fff5f5';
                tr.innerHTML = `
                            <td style="padding:0.75rem;"><strong>${row.name}</strong></td>
                            <td style="padding:0.75rem; text-align:center;">${row.value}</td>
                            <td style="padding:0.75rem; text-align:center;">${row.standard}</td>
                            <td style="padding:0.75rem; text-align:center;">${row.status}</td>
                        `;
                tbody.appendChild(tr);
            });

            if (record && (record.meals_Breakfast || record.meals_Lunch || record.meals_Dinner)) {
                let totalVeg = 0, totalProt = 0, totalCarb = 0;
                [record.meals_Breakfast, record.meals_Lunch, record.meals_Dinner].forEach(meal => {
                    if (!meal) return;
                    if (meal.vegetables && !isNaN(parseFloat(meal.vegetables))) totalVeg += parseFloat(meal.vegetables);
                    if (meal.protein && !isNaN(parseFloat(meal.protein))) totalProt += parseFloat(meal.protein);
                    if (meal.carbs && !isNaN(parseFloat(meal.carbs))) totalCarb += parseFloat(meal.carbs);
                });
                let mealContent = '<div style="line-height:1.8;">';
                if (totalVeg > 0) mealContent += `<div>🥬 蔬菜: ${totalVeg % 1 === 0 ? totalVeg.toFixed(0) : totalVeg.toFixed(1)} 份</div>`;
                if (totalProt > 0) mealContent += `<div>🥩 蛋白質: ${totalProt % 1 === 0 ? totalProt.toFixed(0) : totalProt.toFixed(1)} 份</div>`;
                if (totalCarb > 0) mealContent += `<div>🍚 澱粉: ${totalCarb % 1 === 0 ? totalCarb.toFixed(0) : totalCarb.toFixed(1)} 份</div>`;
                mealContent += '</div>';
                const tr = document.createElement('tr');
                tr.style.background = '#f9fafb';
                tr.innerHTML = `
                            <td style="padding:0.75rem; vertical-align:middle;"><strong>🍽️ 今日三餐</strong></td>
                            <td style="padding:0.75rem; text-align:center; vertical-align:middle;">${mealContent}</td>
                            <td style="padding:0.75rem; text-align:center; vertical-align:middle; color:#6b7280;">-</td>
                            <td style="padding:0.75rem; text-align:center; vertical-align:middle; color:#6b7280;">-</td>
                        `;
                tbody.appendChild(tr);
            }

            if (record && record.beverage) {
                const tr = document.createElement('tr');
                tr.style.background = '#f9fafb';
                tr.innerHTML = `
                            <td style="padding:0.75rem; vertical-align:middle;"><strong>🥤 飲料</strong></td>
                            <td style="padding:0.75rem; text-align:center; vertical-align:middle;">${record.beverage}</td>
                            <td style="padding:0.75rem; text-align:center; vertical-align:middle; color:#6b7280;">-</td>
                            <td style="padding:0.75rem; text-align:center; vertical-align:middle; color:#6b7280;">-</td>
                        `;
                tbody.appendChild(tr);
            }

            if (rows.length === 0 && !record) {
                tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-4">該日期無健康數據</td></tr>';
            }
        }

        // 重置圖表
        function resetZoom(chartName) {
            const chart = charts[chartName];
            if (!chart) return;
            const range = chartInitRanges[chartName];
            if (range) {
                chart.options.scales.x.min = range.min;
                chart.options.scales.x.max = range.max;
                chart.update('none');
            }
            const slider = document.getElementById(chartName + 'Slider');
            if (slider) slider.value = 0;
        }

        // Slider 滑動圖表
        function slideChart(chartName, value) {
            const chart = charts[chartName];
            if (!chart) return;
            const labels = chart.data.labels;
            if (!labels || labels.length === 0) return;
            const xScale = chart.scales.x;
            const visibleCount = xScale.max - xScale.min;
            const totalCount = labels.length - 1;
            const scrollRange = totalCount - visibleCount;
            if (scrollRange <= 0) return;
            const startIdx = Math.round((value / 100) * scrollRange);
            const endIdx = startIdx + visibleCount;
            chart.options.scales.x.min = labels[startIdx];
            chart.options.scales.x.max = labels[Math.min(endIdx, totalCount)];
            chart.update('none');
        }

        function displayChartReport(data) {
            const stats = data.statistics;
            const goals = data.goals || {};

            const sysBPTarget = goals.systolicBPTarget ?? 130;
            const diaBPTarget = goals.diastolicBPTarget ?? 80;
            const glucoseTarget = goals.fastingGlucoseTarget ?? 100;
            const waterTarget = goals.waterTarget ?? 2000;

            document.getElementById('totalDays').textContent = stats.totalDays;
            document.getElementById('highBPDays').textContent = stats.highBPDays;
            document.getElementById('highBSDays').textContent = stats.highBloodSugarDays;
            document.getElementById('lowWaterDays').textContent = stats.lowWaterDays;
            document.getElementById('lowExerciseDays').textContent = stats.lowExerciseDays;

            const avgSys = stats.avgSystolicBP ?? null;
            const avgDia = stats.avgDiastolicBP ?? null;
            const avgBS = stats.avgBloodSugar ?? null;
            const avgWater = stats.avgWaterIntake ?? null;
            const avgEx = stats.avgExerciseDuration ?? null;
            const avgCig = stats.avgCigarettes ?? 0;
            const avgBetel = stats.avgBetelNut ?? 0;
            const avgVeg = stats.avgVegetables ?? null;
            const avgProt = stats.avgProtein ?? null;
            const avgCarbs = stats.avgCarbs ?? null;

            const bpAbnormal = (avgSys !== null && avgSys > sysBPTarget) || (avgDia !== null && avgDia > diaBPTarget);
            const bsAbnormal = avgBS !== null && avgBS > glucoseTarget;
            const waterLow = avgWater !== null && avgWater < waterTarget;
            const exLow = avgEx !== null && avgEx < 150;

            const badge = (text, type) => {
                const colors = { success: 'background:#4CAF50; color:#fff;', danger: 'background:#F44336; color:#fff;', warning: 'background:#FF9800; color:#fff;' };
                return `<span style="display:inline-block; padding:0.35rem 1rem; border-radius:20px; font-size:0.85rem; font-weight:600; ${colors[type]}">${text}</span>`;
            };

            document.getElementById('avgTable').innerHTML = `
                        <tr>
                            <td>❤️ 血壓</td>
                            <td style="text-align:center;">${avgSys !== null ? avgSys.toFixed(1) : 'N/A'} / ${avgDia !== null ? avgDia.toFixed(1) : 'N/A'} mmHg</td>
                            <td style="text-align:center;">≤ ${sysBPTarget}/${diaBPTarget} mmHg</td>
                            <td style="text-align:center;">${avgSys === null && avgDia === null ? badge('無資料', 'warning') : bpAbnormal ? badge('⚠️ 偏高', 'danger') : badge('✓ 正常', 'success')}</td>
                        </tr>
                        <tr>
                            <td>🩸 血糖</td>
                            <td style="text-align:center;">${avgBS !== null ? avgBS.toFixed(1) : 'N/A'} mg/dL</td>
                            <td style="text-align:center;">≤ ${glucoseTarget} mg/dL</td>
                            <td style="text-align:center;">${avgBS === null ? badge('無資料', 'warning') : bsAbnormal ? badge('⚠️ 偏高', 'danger') : badge('✓ 正常', 'success')}</td>
                        </tr>
                        <tr>
                            <td>💧 飲水量</td>
                            <td style="text-align:center;">${avgWater !== null ? avgWater.toFixed(0) : 'N/A'} ml</td>
                            <td style="text-align:center;">≥ ${waterTarget} ml</td>
                            <td style="text-align:center;">${avgWater === null ? badge('無資料', 'warning') : waterLow ? badge('⚠️ 不足', 'danger') : badge('✓ 充足', 'success')}</td>
                        </tr>
                        <tr>
                            <td>🏃 運動時間</td>
                            <td style="text-align:center;">${avgEx !== null ? avgEx.toFixed(1) : 'N/A'} 分鐘</td>
                            <td style="text-align:center;">≥ 150 分鐘/週</td>
                            <td style="text-align:center;">${avgEx === null ? badge('無資料', 'warning') : exLow ? badge('⚠️ 不足', 'danger') : badge('✓ 充足', 'success')}</td>
                        </tr>
                        <tr>
                            <td>🚬 抽菸 (每日平均)</td>
                            <td style="text-align:center;">${avgCig.toFixed(1)} 支</td>
                            <td style="text-align:center;">0 支</td>
                            <td style="text-align:center;">${avgCig > 0 ? badge('⚠️ 建議戒菸', 'danger') : badge('✓ 良好', 'success')}</td>
                        </tr>
                        <tr>
                            <td>🌿 檳榔 (每日平均)</td>
                            <td style="text-align:center;">${avgBetel.toFixed(1)} 次</td>
                            <td style="text-align:center;">0 次</td>
                            <td style="text-align:center;">${avgBetel > 0 ? badge('⚠️ 建議戒除', 'danger') : badge('✓ 良好', 'success')}</td>
                        </tr>
                        <tr>
                            <td>🥬 蔬菜 (每日平均)</td>
                            <td style="text-align:center;">${avgVeg !== null ? avgVeg.toFixed(1) : 'N/A'} 份</td>
                            <td style="text-align:center;">建議 3-5 份</td>
                            <td style="text-align:center;">${avgVeg === null ? badge('無資料', 'warning') : avgVeg >= 3 ? badge('✓ 充足', 'success') : badge('⚠️ 可增加', 'danger')}</td>
                        </tr>
                        <tr>
                            <td>🥩 蛋白質 (每日平均)</td>
                            <td style="text-align:center;">${avgProt !== null ? avgProt.toFixed(1) : 'N/A'} 份</td>
                            <td style="text-align:center;">建議 3-5 份</td>
                            <td style="text-align:center;">${avgProt === null ? badge('無資料', 'warning') : avgProt >= 3 ? badge('✓ 充足', 'success') : badge('⚠️ 可增加', 'danger')}</td>
                        </tr>
                        <tr>
                            <td>🍚 澱粉 (每日平均)</td>
                            <td style="text-align:center;">${avgCarbs !== null ? avgCarbs.toFixed(1) : 'N/A'} 份</td>
                            <td style="text-align:center;">建議 2-4 份</td>
                            <td style="text-align:center;">${avgCarbs === null ? badge('無資料', 'warning') : (avgCarbs >= 2 && avgCarbs <= 4) ? badge('✓ 適中', 'success') : badge('⚠️ 需調整', 'danger')}</td>
                        </tr>
                    `;

            drawCharts(data.charts);
            displayMealRecords(data, currentReportType);
        }

        function displayMealRecords(data, reportType) {
            const mealDiv = document.getElementById('mealTable');
            let summary;
            if (reportType === 1) summary = data.charts.weeklyMealSummary;
            else if (reportType === 2) summary = data.charts.monthlyMealSummary;
            else if (reportType === 3) summary = data.charts.yearlyMealSummary;

            const periodLabel = reportType === 1 ? '當週' : reportType === 2 ? '當月' : '全年';

            const summaryHtml = summary ? `
                        <div style="background: #fef3c7; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; border-left: 4px solid #f59e0b;">
                            <h4 style="margin: 0 0 0.5rem 0; color: #92400e;">📊 ${periodLabel}飲食統計</h4>
                            <div style="font-size: 0.85rem; color: #78350f; margin-bottom: 0.5rem;">
                                ※ 平均值以有記錄的 <strong>${summary.daysWithMeals}</strong> 天計算
                            </div>
                            <div style="line-height: 1.8;">
                                <div>🥬 蔬菜: 總計 ${summary.totalVegetables?.toFixed(1) ?? 0} 份 &nbsp;│&nbsp; 每日平均 <strong>${summary.avgVegetables?.toFixed(1) ?? 0} 份</strong></div>
                                <div>🥩 蛋白質: 總計 ${summary.totalProtein?.toFixed(1) ?? 0} 份 &nbsp;│&nbsp; 每日平均 <strong>${summary.avgProtein?.toFixed(1) ?? 0} 份</strong></div>
                                <div>🍚 澱粉: 總計 ${summary.totalCarbs?.toFixed(1) ?? 0} 份 &nbsp;│&nbsp; 每日平均 <strong>${summary.avgCarbs?.toFixed(1) ?? 0} 份</strong></div>
                            </div>
                        </div>` : '';

            mealDiv.innerHTML = summaryHtml || '<p style="text-align:center; padding:1rem; color:#999;">無三餐記錄</p>';
        }

        function drawCharts(chartData) {
            Object.values(charts).forEach(chart => { if (chart) chart.destroy(); });
            charts = {};

            const getInitRange = (data) => {
                if (!data || data.length === 0) return { min: null, max: null };
                if (!currentReport?.startDate) return { min: data[0].date, max: data[data.length - 1].date };
                const start = new Date(currentReport.startDate);
                const end = new Date(currentReport.endDate);
                let minLabel = null, maxLabel = null;
                data.forEach(d => {
                    const parts = d.date.split('/');
                    const m = parseInt(parts[0]), day = parseInt(parts[1]);
                    if (!minLabel && m === start.getMonth() + 1 && day >= start.getDate()) minLabel = d.date;
                    if (m === end.getMonth() + 1 && day <= end.getDate()) maxLabel = d.date;
                });
                return { min: minLabel ?? data[0].date, max: maxLabel ?? data[data.length - 1].date };
            };

            const zoomCfg = {
                pan: { enabled: true, mode: 'x' },
                zoom: { wheel: { enabled: true }, pinch: { enabled: true }, mode: 'x' }
            };

            if (chartData.bloodPressureData && chartData.bloodPressureData.length > 0) {
                const { min, max } = getInitRange(chartData.bloodPressureData);
                charts.bp = new Chart(document.getElementById('bpChart').getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: chartData.bloodPressureData.map(d => d.date),
                        datasets: [
                            { label: '收縮壓', data: chartData.bloodPressureData.map(d => d.value), borderColor: 'rgb(220,38,38)', backgroundColor: 'rgba(220,38,38,0.1)', tension: 0.4, fill: true },
                            { label: '舒張壓', data: chartData.bloodPressureData.map(d => d.value2), borderColor: 'rgb(37,99,235)', backgroundColor: 'rgba(37,99,235,0.1)', tension: 0.4, fill: true }
                        ]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { title: { display: true, text: '❤️ 血壓趨勢' }, zoom: zoomCfg }, scales: { x: { min, max }, y: { beginAtZero: true, title: { display: true, text: 'mmHg' } } } }
                });
                chartInitRanges.bp = { min, max };
                document.getElementById('bpSlider').value = 0;
            }

            if (chartData.bloodSugarData && chartData.bloodSugarData.length > 0) {
                const { min, max } = getInitRange(chartData.bloodSugarData);
                charts.bs = new Chart(document.getElementById('bsChart').getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: chartData.bloodSugarData.map(d => d.date),
                        datasets: [{ label: '血糖', data: chartData.bloodSugarData.map(d => d.value), borderColor: 'rgb(220,38,38)', backgroundColor: 'rgba(220,38,38,0.1)', tension: 0.4, fill: true, pointBackgroundColor: chartData.bloodSugarData.map(d => d.isAbnormal ? 'red' : 'green') }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { title: { display: true, text: '🩸 血糖趨勢 (標準值: ≤99 mg/dL)' }, zoom: zoomCfg }, scales: { x: { min, max }, y: { beginAtZero: true, title: { display: true, text: 'mg/dL' } } } }
                });
                chartInitRanges.bs = { min, max };
                document.getElementById('bsSlider').value = 0;
            }

            if (chartData.waterIntakeData && chartData.waterIntakeData.length > 0) {
                const { min, max } = getInitRange(chartData.waterIntakeData);
                charts.water = new Chart(document.getElementById('waterChart').getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: chartData.waterIntakeData.map(d => d.date),
                        datasets: [{ label: '飲水量 (ml)', data: chartData.waterIntakeData.map(d => d.value), backgroundColor: chartData.waterIntakeData.map(d => d.isAbnormal ? 'rgba(239,108,0,0.6)' : 'rgba(6,182,212,0.6)'), borderColor: chartData.waterIntakeData.map(d => d.isAbnormal ? 'rgb(239,108,0)' : 'rgb(8,145,178)'), borderWidth: 1 }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { title: { display: true, text: '💧 飲水量趨勢 (建議: ≥2000 ml)' }, zoom: zoomCfg }, scales: { x: { min, max }, y: { beginAtZero: true, title: { display: true, text: 'ml' } } } }
                });
                chartInitRanges.water = { min, max };
                document.getElementById('waterSlider').value = 0;
            }

            if (chartData.exerciseDurationData && chartData.exerciseDurationData.length > 0) {
                const { min, max } = getInitRange(chartData.exerciseDurationData);
                charts.exercise = new Chart(document.getElementById('exerciseChart').getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: chartData.exerciseDurationData.map(d => d.date),
                        datasets: [{ label: '運動時間 (分鐘)', data: chartData.exerciseDurationData.map(d => d.value), backgroundColor: chartData.exerciseDurationData.map(d => d.isAbnormal ? 'rgba(239,108,0,0.6)' : 'rgba(16,185,129,0.6)'), borderColor: chartData.exerciseDurationData.map(d => d.isAbnormal ? 'rgb(239,108,0)' : 'rgb(5,150,105)'), borderWidth: 1 }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { title: { display: true, text: '🏃 運動時間趨勢 (建議: ≥150 分鐘/週)' }, zoom: zoomCfg }, scales: { x: { min, max }, y: { beginAtZero: true, title: { display: true, text: '分鐘' } } } }
                });
                chartInitRanges.exercise = { min, max };
                document.getElementById('exerciseSlider').value = 0;
            }

            if (chartData.cigarettesData && chartData.cigarettesData.length > 0) {
                const { min, max } = getInitRange(chartData.cigarettesData);
                charts.cigarette = new Chart(document.getElementById('cigaretteChart').getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: chartData.cigarettesData.map(d => d.date),
                        datasets: [{ label: '抽菸支數', data: chartData.cigarettesData.map(d => d.value), borderColor: 'rgb(220,38,38)', backgroundColor: 'rgba(220,38,38,0.1)', tension: 0.4, fill: true, pointBackgroundColor: chartData.cigarettesData.map(d => d.isAbnormal ? 'rgb(220,38,38)' : 'rgb(22,163,74)') }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { title: { display: true, text: '🚬 抽菸趨勢 (建議: 0 支)' }, zoom: zoomCfg }, scales: { x: { min, max }, y: { beginAtZero: true, title: { display: true, text: '支' } } } }
                });
                chartInitRanges.cigarette = { min, max };
                document.getElementById('cigaretteSlider').value = 0;
            }

            if (chartData.betelNutData && chartData.betelNutData.length > 0) {
                const { min, max } = getInitRange(chartData.betelNutData);
                charts.betelNut = new Chart(document.getElementById('betelNutChart').getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: chartData.betelNutData.map(d => d.date),
                        datasets: [{ label: '檳榔次數', data: chartData.betelNutData.map(d => d.value), borderColor: 'rgb(22,163,74)', backgroundColor: 'rgba(22,163,74,0.1)', tension: 0.4, fill: true, pointBackgroundColor: chartData.betelNutData.map(d => d.isAbnormal ? 'rgb(220,38,38)' : 'rgb(22,163,74)') }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { title: { display: true, text: '🌿 檳榔趨勢 (建議: 0 顆)' }, zoom: zoomCfg }, scales: { x: { min, max }, y: { beginAtZero: true, title: { display: true, text: '顆' } } } }
                });
                chartInitRanges.betelNut = { min, max };
                document.getElementById('betelNutSlider').value = 0;
            }
        }

        // 測試傳送週報到 LINE
        async function testWeeklyReport() {
            if (!confirm('確定要傳送上週健康週報到您的 LINE 嗎？\n\n注意：需要先綁定 LINE 帳號才能接收週報。')) return;

            const btn = event.target;
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '📤 傳送中...';

            try {
                const response = await fetch('/Analysis/TestWeeklyReport', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                const result = await response.json();
                alert(result.success ? '✅ ' + result.message : '❌ ' + result.message);
            } catch (error) {
                alert('❌ 系統錯誤: ' + error.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }
    </script>
</body>
</html>
