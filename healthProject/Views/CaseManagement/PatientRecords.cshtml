@model List<CaseManagementViewModel>
@{
    ViewData["Title"] = "我的疾病管理紀錄";
    Layout = null;
    var userName = User.FindFirst("FullName")?.Value ?? User.Identity.Name;
    var totalCount = Model?.Count ?? 0;
    var annualCount = Model?.Count(r => r.AnnualAssessment) ?? 0;
    var nextFollowUp = Model?
        .Where(r => r.FollowUpDate.HasValue && r.FollowUpDate.Value >= DateTime.Today)
        .OrderBy(r => r.FollowUpDate)
        .FirstOrDefault();
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>我的疾病管理紀錄 — 代謝症候群疾病管理與追蹤系統</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --navy: #0a2540;
            --navy-mid: #103a5e;
            --blue: #1a6fb5;
            --blue-lt: #2589d8;
            --bg: #f4f6f9;
            --surface: #ffffff;
            --border: #dde3ea;
            --text: #1a2635;
            --text-sub: #5a6a7e;
            --text-pale: #8fa0b4;
            --green: #2e7d32;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            min-height: 100%;
            font-family: 'Noto Sans TC', 'Microsoft JhengHei', sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        /* ── TOP BAR ── */
        .topbar {
            background: var(--navy);
            height: 56px;
            display: flex;
            align-items: center;
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 12px rgba(0,0,0,0.25);
        }

        .topbar-logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            color: white;
            font-weight: 700;
            font-size: 1rem;
        }

        .cross {
            width: 28px;
            height: 28px;
            background: var(--blue-lt);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            font-weight: 900;
            color: white;
        }

        .topbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .topbar-user {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: rgba(255,255,255,0.75);
            font-size: 0.82rem;
        }

        .user-avatar {
            width: 28px;
            height: 28px;
            background: var(--blue-lt);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 700;
            color: white;
        }

        .topbar-back {
            color: rgba(255,255,255,0.65);
            background: none;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 6px;
            padding: 0.3rem 0.85rem;
            font-size: 0.8rem;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.35rem;
            transition: all 0.2s;
        }

            .topbar-back:hover {
                background: rgba(255,255,255,0.1);
                color: white;
                text-decoration: none;
            }

        /* ── HERO ── */
        .hero {
            background: linear-gradient(100deg, var(--navy-mid) 0%, var(--blue) 100%);
            padding: 2rem 2.5rem 1.75rem;
            position: relative;
            overflow: hidden;
        }

            .hero::after {
                content: '';
                position: absolute;
                right: -60px;
                top: -60px;
                width: 240px;
                height: 240px;
                border-radius: 50%;
                background: rgba(255,255,255,0.04);
                pointer-events: none;
            }

        .hero-eyebrow {
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5);
            margin-bottom: 0.4rem;
        }

        .hero-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: white;
            margin-bottom: 0.4rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .hero-sub {
            font-size: 0.82rem;
            color: rgba(255,255,255,0.55);
        }

        /* ── CONTENT ── */
        .content {
            padding: 2rem 2.5rem;
            

        }

        /* ── STATS ROW ── */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1px;
            background: var(--border);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 1.5rem;
            box-shadow: 0 1px 4px rgba(0,0,0,0.05);
        }

        .stat-cell {
            background: var(--surface);
            padding: 1.25rem;
            text-align: center;
        }

        .stat-num {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--navy);
            line-height: 1;
            margin-bottom: 0.3rem;
        }

        .stat-label {
            font-size: 0.75rem;
            color: var(--text-pale);
            font-weight: 500;
        }

        /* ── RECORDS ── */
        .records-list {
            display: flex;
            flex-direction: column;
            gap: 1px;
            background: var(--border);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
            margin-bottom: 1.5rem;
        }

        .record-item {
            background: var(--surface);
            padding: 1.25rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 1.25rem;
            transition: background 0.15s;
            flex-wrap: wrap;
        }

            .record-item:hover {
                background: #f8fafc;
            }

        .record-left {
            flex-shrink: 0;
            text-align: center;
            min-width: 80px;
        }

        .record-date-day {
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--navy);
            line-height: 1;
        }

        .record-date-ym {
            font-size: 0.72rem;
            color: var(--text-pale);
            margin-top: 0.2rem;
        }

        .record-divider {
            width: 1px;
            background: var(--border);
            align-self: stretch;
            flex-shrink: 0;
        }

        .record-middle {
            flex: 1;
            min-width: 200px;
        }

        .record-type-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            font-size: 0.72rem;
            font-weight: 600;
            padding: 0.2rem 0.6rem;
            border-radius: 20px;
            margin-bottom: 0.6rem;
        }

        .badge-annual {
            background: #e8f1fb;
            color: var(--blue);
        }

        .badge-followup {
            background: #e8f5e9;
            color: var(--green);
        }

        .metrics-row {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .metric-chip {
            font-size: 0.78rem;
            color: var(--text-sub);
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

            .metric-chip strong {
                color: var(--text);
                font-weight: 600;
            }

        .followup-note {
            margin-top: 0.6rem;
            font-size: 0.75rem;
            color: var(--green);
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

        .record-right {
            flex-shrink: 0;
        }

        .btn-detail {
            padding: 0.5rem 1rem;
            background: var(--navy);
            border: none;
            border-radius: 7px;
            color: white;
            font-size: 0.8rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            transition: background 0.15s;
            white-space: nowrap;
        }

            .btn-detail:hover {
                background: var(--navy-mid);
                color: white;
                text-decoration: none;
            }

        /* 空狀態 */
        .empty-state {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 3.5rem;
            text-align: center;
            color: var(--text-pale);
            margin-bottom: 1.5rem;
        }

            .empty-state i {
                font-size: 2.5rem;
                display: block;
                margin-bottom: 0.75rem;
            }

            .empty-state p {
                font-size: 0.9rem;
            }

        /* ── RESPONSIVE ── */
        @@media (max-width: 768px) {
            .topbar {
                padding: 0 1rem;
            }

            .topbar-user {
                display: none;
            }

            .hero {
                padding: 1.5rem 1.25rem;
            }

            .content {
                padding: 1.25rem;
            }

            .stats-row {
                grid-template-columns: 1fr 1fr 1fr;
            }

            .record-divider {
                display: none;
            }
        }

        @@media (max-width: 480px) {
            .stats-row {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <!-- TOP BAR -->
    <header class="topbar">
        <div class="topbar-logo">
            <div class="cross">✚</div>
            代謝症候群疾病管理與追蹤系統
        </div>
        <div class="topbar-right">
            <div class="topbar-user">
                <div class="user-avatar">@(userName?.Length > 0 ? userName[0].ToString() : "用")</div>
                <span>@userName</span>
            </div>
            <a href="@Url.Action("Dashboard", "Home")" class="topbar-back">
                <i class="bi bi-arrow-left"></i> 返回主選單
            </a>
        </div>
    </header>

    <!-- HERO -->
    <div class="hero">
        <div class="hero-eyebrow">Case Records</div>
        <div class="hero-title">
            <i class="bi bi-clipboard2-pulse"></i>
            我的疾病管理紀錄
        </div>
        <div class="hero-sub">查看您的歷次評估與追蹤紀錄</div>
    </div>

    <!-- CONTENT -->
    <div class="content">

        <!-- 統計列 -->
        <div class="stats-row">
            <div class="stat-cell">
                <div class="stat-num">@totalCount</div>
                <div class="stat-label">總紀錄數</div>
            </div>
            <div class="stat-cell">
                <div class="stat-num">@annualCount</div>
                <div class="stat-label">年度評估</div>
            </div>
            <div class="stat-cell">
                <div class="stat-num" style="font-size:@(nextFollowUp != null ? "1.4rem" : "1.8rem");">
                    @(nextFollowUp != null ? nextFollowUp.FollowUpDate!.Value.ToString("MM/dd") : "—")
                </div>
                <div class="stat-label">下次追蹤</div>
            </div>
        </div>

        <!-- 紀錄列表 -->
        @if (Model != null && Model.Any())
        {
            <div class="records-list">
                @foreach (var record in Model.OrderByDescending(r => r.AssessmentDate ?? r.AnnualAssessment_Date ?? DateTime.MinValue))
                {
                    var assessDate = record.AssessmentDate ?? record.AnnualAssessment_Date;
                    <div class="record-item">

                        <!-- 日期 -->
                        <div class="record-left">
                            <div class="record-date-day">@(assessDate?.Day.ToString("00") ?? "--")</div>
                            <div class="record-date-ym">@(assessDate?.ToString("yyyy/MM") ?? "未設定")</div>
                        </div>

                        <div class="record-divider"></div>

                        <!-- 內容 -->
                        <div class="record-middle">
                            <span class="record-type-badge @(record.AnnualAssessment ? "badge-annual" : "badge-followup")">
                                <i class="bi bi-@(record.AnnualAssessment ? "calendar-check" : "arrow-repeat")"></i>
                                @(record.AnnualAssessment ? "年度評估" : "追蹤紀錄")
                            </span>

                            <div class="metrics-row">
                                @if (record.Height > 0)
                                {
                                    <span class="metric-chip"><i class="bi bi-rulers"></i> <strong>@record.Height</strong> cm</span>
                                }
                                @if (record.Weight > 0)
                                {
                                    <span class="metric-chip"><i class="bi bi-person"></i> <strong>@record.Weight</strong> kg</span>
                                }
                                @if (record.BMI && record.BMI_Value.HasValue)
                                {
                                    <span class="metric-chip">BMI <strong>@record.BMI_Value.Value.ToString("0.0")</strong></span>
                                }
                                @if (record.SystolicBP && record.SystolicBP_Value.HasValue)
                                {
                                    <span class="metric-chip"><i class="bi bi-heart-pulse"></i> <strong>@record.SystolicBP_Value/@(record.DiastolicBP_Value ?? 0)</strong></span>
                                }
                                @if (record.CurrentWaist && record.CurrentWaist_Value.HasValue)
                                {
                                    <span class="metric-chip"><i class="bi bi-arrows-expand"></i> <strong>@record.CurrentWaist_Value</strong> cm</span>
                                }
                                @if (record.FastingGlucose && record.FastingGlucose_Value.HasValue)
                                {
                                    <span class="metric-chip"><i class="bi bi-droplet"></i> <strong>@record.FastingGlucose_Value</strong> mg/dL</span>
                                }
                            </div>

                            @if (record.FollowUpDate.HasValue)
                            {
                                <div class="followup-note">
                                    <i class="bi bi-pin-fill"></i>
                                    下次追蹤：@record.FollowUpDate.Value.ToString("yyyy 年 MM 月 dd 日")
                                </div>
                            }
                        </div>

                        <!-- 操作 -->
                        <div class="record-right">
                            <a href="@Url.Action("Details", "CaseManagement", new { id = record.Id })" class="btn-detail">
                                查看詳情 <i class="bi bi-chevron-right"></i>
                            </a>
                        </div>

                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p>目前還沒有任何紀錄</p>
                <p style="margin-top:0.3rem; font-size:0.8rem;">您的健康管理紀錄將會顯示在這裡</p>
            </div>
        }

    </div>

</body>
</html>
