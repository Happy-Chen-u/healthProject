@model IEnumerable<healthProject.Models.TargetSummaryViewModel>
@{
    ViewData["Title"] = "個案目標達成狀況";
    Layout = null;
    var userName = User.FindFirst("FullName")?.Value ?? User.Identity.Name;
    var totalCount = Model?.Count() ?? 0;
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>個案目標達成狀況 — 代謝症候群疾病管理與追蹤系統</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --navy: #0a2540;
            --navy-mid: #103a5e;
            --blue: #1a6fb5;
            --blue-lt: #2589d8;
            --bg: #f4f6f9;
            --surface: #ffffff;
            --border: #dde3ea;
            --text: #1a2635;
            --text-sub: #5a6a7e;
            --text-pale: #8fa0b4;
            --green: #2e7d32;
            --red: #c0392b;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            min-height: 100%;
            font-family: 'Noto Sans TC', 'Microsoft JhengHei', sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        /* ── TOP BAR ── */
        .topbar {
            background: var(--navy);
            height: 56px;
            display: flex;
            align-items: center;
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 12px rgba(0,0,0,0.25);
        }

        .topbar-logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            color: white;
            font-weight: 700;
            font-size: 1rem;
        }

        .cross {
            width: 28px;
            height: 28px;
            background: var(--blue-lt);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            font-weight: 900;
            color: white;
        }

        .topbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .topbar-user {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: rgba(255,255,255,0.75);
            font-size: 0.82rem;
        }

        .user-avatar {
            width: 28px;
            height: 28px;
            background: var(--blue-lt);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 700;
            color: white;
        }

        .topbar-back {
            color: rgba(255,255,255,0.65);
            background: none;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 6px;
            padding: 0.3rem 0.85rem;
            font-size: 0.8rem;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.35rem;
            transition: all 0.2s;
        }

            .topbar-back:hover {
                background: rgba(255,255,255,0.1);
                color: white;
                text-decoration: none;
            }

        /* ── HERO ── */
        .hero {
            background: linear-gradient(100deg, var(--navy-mid) 0%, var(--blue) 100%);
            padding: 2rem 2.5rem 1.75rem;
            position: relative;
            overflow: hidden;
        }

            .hero::after {
                content: '';
                position: absolute;
                right: -60px;
                top: -60px;
                width: 240px;
                height: 240px;
                border-radius: 50%;
                background: rgba(255,255,255,0.04);
                pointer-events: none;
            }

        .hero-eyebrow {
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5);
            margin-bottom: 0.4rem;
        }

        .hero-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: white;
            margin-bottom: 0.4rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .hero-sub {
            font-size: 0.82rem;
            color: rgba(255,255,255,0.55);
        }

        /* ── CONTENT ── */
        .content {
            padding: 2rem 2.5rem;
        }

        /* ── SEARCH BAR ── */
        .search-bar {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1rem 1.25rem;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-wrap: wrap;
            box-shadow: 0 1px 4px rgba(0,0,0,0.05);
        }

        .search-label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-sub);
            white-space: nowrap;
        }

        .search-input {
            flex: 1;
            min-width: 220px;
            padding: 0.6rem 0.9rem;
            border: 1.5px solid var(--border);
            border-radius: 7px;
            font-size: 0.88rem;
            font-family: inherit;
            color: var(--text);
            outline: none;
            transition: border-color 0.2s;
        }

            .search-input:focus {
                border-color: var(--blue-lt);
                box-shadow: 0 0 0 3px rgba(37,137,216,0.1);
            }

            .search-input::placeholder {
                color: var(--text-pale);
            }

        .btn-search {
            padding: 0.6rem 1.25rem;
            background: var(--navy);
            border: none;
            border-radius: 7px;
            color: white;
            font-size: 0.85rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.35rem;
            transition: background 0.15s;
        }

            .btn-search:hover {
                background: var(--navy-mid);
            }

        .btn-clear {
            padding: 0.6rem 1rem;
            background: var(--surface);
            border: 1.5px solid var(--border);
            border-radius: 7px;
            color: var(--text-sub);
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.35rem;
            transition: background 0.15s;
        }

            .btn-clear:hover {
                background: var(--bg);
                text-decoration: none;
                color: var(--text-sub);
            }

        /* ── TABLE CARD ── */
        .table-card {
            background: var(--surface);
            border-radius: 12px;
            border: 1px solid var(--border);
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
            overflow: hidden;
        }

        .table-card-header {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--border);
            background: var(--bg);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .table-card-title {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-sub);
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .count-badge {
            background: var(--navy);
            color: white;
            font-size: 0.72rem;
            font-weight: 700;
            padding: 0.15rem 0.55rem;
            border-radius: 20px;
        }

        /* ── TABLE ── */
        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

            .data-table thead th {
                background: var(--bg);
                padding: 0.75rem 1rem;
                font-size: 0.78rem;
                font-weight: 600;
                color: var(--text-sub);
                text-align: left;
                border-bottom: 1px solid var(--border);
                letter-spacing: 0.03em;
            }

                .data-table thead th.center {
                    text-align: center;
                }

            .data-table tbody td {
                padding: 0.85rem 1rem;
                font-size: 0.88rem;
                border-bottom: 1px solid var(--border);
                vertical-align: middle;
            }

            .data-table tbody tr:last-child td {
                border-bottom: none;
            }

            .data-table tbody tr:hover {
                background: #f8fafc;
            }

        .td-center {
            text-align: center;
        }

        /* 達成/未達成 數字 */
        .badge-achieved {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            background: #e8f5e9;
            color: var(--green);
            font-size: 0.82rem;
            font-weight: 600;
            padding: 0.25rem 0.65rem;
            border-radius: 20px;
        }

        .badge-unachieved {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            background: #fdecea;
            color: var(--red);
            font-size: 0.82rem;
            font-weight: 600;
            padding: 0.25rem 0.65rem;
            border-radius: 20px;
        }

        /* 詳細按鈕 */
        .btn-detail {
            padding: 0.4rem 0.9rem;
            background: var(--blue);
            border: none;
            border-radius: 6px;
            color: white;
            font-size: 0.78rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            transition: background 0.15s;
        }

            .btn-detail:hover {
                background: var(--blue-lt);
                color: white;
                text-decoration: none;
            }

        /* 無資料 */
        .empty-state {
            padding: 3rem;
            text-align: center;
            color: var(--text-pale);
        }

            .empty-state i {
                font-size: 2.5rem;
                margin-bottom: 0.75rem;
                display: block;
            }

            .empty-state p {
                font-size: 0.9rem;
            }

        /* ── RESPONSIVE ── */
        @@media (max-width: 768px) {
            .topbar {
                padding: 0 1rem;
            }

            .topbar-user {
                display: none;
            }

            .hero {
                padding: 1.5rem 1.25rem;
            }

            .content {
                padding: 1.25rem;
            }

            .data-table {
                display: block;
                overflow-x: auto;
            }
        }
    </style>
</head>
<body>

    <!-- TOP BAR -->
    <header class="topbar">
        <div class="topbar-logo">
            <div class="cross">✚</div>
            代謝症候群疾病管理與追蹤系統
        </div>
        <div class="topbar-right">
            <div class="topbar-user">
                <div class="user-avatar">@(userName?.Length > 0 ? userName[0].ToString() : "醫")</div>
                <span>@userName</span>
            </div>
            <a href="@Url.Action("Index", "CaseManagement")" class="topbar-back">
                <i class="bi bi-arrow-left"></i> 返回上一頁
            </a>
        </div>
    </header>

    <!-- HERO -->
    <div class="hero">
        <div class="hero-eyebrow">Target Achievement</div>
        <div class="hero-title">
            <i class="bi bi-bullseye"></i>
            個案目標達成狀況
        </div>
        <div class="hero-sub">查看個案是否達成每次評估設定的目標值</div>
    </div>

    <!-- CONTENT -->
    <div class="content">

        <!-- 搜尋列 -->
        <div class="search-bar">
            <span class="search-label"><i class="bi bi-search"></i> 搜尋</span>
            <form asp-action="ViewTargets" method="get" style="display:contents;">
                <input type="text" name="idNumber" class="search-input"
                       placeholder="輸入身分證字號查詢"
                       value="@ViewBag.SearchIdNumber" />
                <button type="submit" class="btn-search">
                    <i class="bi bi-search"></i> 查詢
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchIdNumber as string))
                {
                    <a href="@Url.Action("ViewTargets", "CaseManagement")" class="btn-clear">
                        <i class="bi bi-x"></i> 清除
                    </a>
                }
            </form>
        </div>

        <!-- 資料表格 -->
        <div class="table-card">
            <div class="table-card-header">
                <span class="table-card-title">
                    <i class="bi bi-table"></i>
                    個案列表
                </span>
                <span class="count-badge">共 @totalCount 筆</span>
            </div>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <p>查無資料</p>
                </div>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>姓名</th>
                            <th>身分證字號</th>
                            <th class="center">達成項目</th>
                            <th class="center">未達成項目</th>
                            <th class="center">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.Name</strong></td>
                                <td style="color:var(--text-sub); font-size:0.83rem;">@item.IDNumber</td>
                                <td class="td-center">
                                    <span class="badge-achieved">
                                        <i class="bi bi-check-circle-fill"></i>
                                        @item.AchievedCount
                                    </span>
                                </td>
                                <td class="td-center">
                                    <span class="badge-unachieved">
                                        <i class="bi bi-x-circle-fill"></i>
                                        @item.UnachievedCount
                                    </span>
                                </td>
                                <td class="td-center">
                                    <a asp-action="TargetDetails"
                                       asp-route-idNumber="@item.IDNumber"
                                       class="btn-detail">
                                        <i class="bi bi-clipboard2-data"></i>
                                        查看詳細
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

    </div>

</body>
</html>
