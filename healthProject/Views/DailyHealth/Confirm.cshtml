@model HealthRecordViewModel
@{
    ViewData["Title"] = "確認資料";
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --navy:     #0a2540;
            --navy-mid: #103a5e;
            --blue:     #1a6fb5;
            --blue-lt:  #2589d8;
            --bg:       #f4f6f9;
            --surface:  #ffffff;
            --border:   #dde3ea;
            --text:     #1a2635;
            --text-sub: #5a6a7e;
            --text-pale:#8fa0b4;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            font-family: 'Noto Sans TC', 'Microsoft JhengHei', Arial, sans-serif;
            color: var(--text);
            min-height: 100vh;
        }

        /* TOP BAR */
        .topbar {
            background: var(--navy);
            height: 56px;
            display: flex;
            align-items: center;
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 12px rgba(0,0,0,0.25);
        }
        .topbar-logo { display: flex; align-items: center; gap: 0.6rem; color: white; font-weight: 700; font-size: 1rem; }
        .cross { width: 28px; height: 28px; background: var(--blue-lt); border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 1rem; font-weight: 900; color: white; }

        /* HERO */
        .hero {
            background: linear-gradient(100deg, var(--navy-mid) 0%, var(--blue) 100%);
            padding: 1.5rem 2rem;
        }
        .hero-title { font-size: 1.2rem; font-weight: 700; color: white; display: flex; align-items: center; gap: 0.5rem; }
        .hero-sub { font-size: 0.8rem; color: rgba(255,255,255,0.6); margin-top: 0.2rem; }

        /* MAIN */
        .main-container {
            max-width: 780px;
            margin: 1.25rem auto;
            padding: 0 1.25rem;
        }

        /* WARNING */
        .warn-box {
            background: #fef2f2;
            border: 1.5px solid #fca5a5;
            border-left: 4px solid #dc2626;
            border-radius: 8px;
            padding: 0.85rem 1rem;
            margin-bottom: 1rem;
            font-size: 0.85rem;
        }
        .warn-title { color: #dc2626; font-weight: 700; display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.5rem; }
        .warn-item { color: #b91c1c; font-weight: 600; padding: 0.2rem 0; }
        .warn-hint { color: #991b1b; font-size: 0.8rem; margin-top: 0.5rem; background: #fff0f0; padding: 0.5rem 0.75rem; border-radius: 5px; }

        /* CARD */
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
            margin-bottom: 0.75rem;
            overflow: hidden;
        }
        .card-header {
            background: var(--bg);
            border-bottom: 1px solid var(--border);
            padding: 0.6rem 1rem;
            font-size: 0.82rem;
            font-weight: 700;
            color: var(--text-sub);
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }
        .card-body { padding: 0.85rem 1rem; }

        /* DATA ROW */
        .data-row {
            display: flex;
            align-items: baseline;
            padding: 0.35rem 0;
            border-bottom: 1px solid var(--bg);
            font-size: 0.88rem;
            gap: 0.5rem;
        }
        .data-row:last-child { border-bottom: none; }
        .data-label { color: var(--text-sub); min-width: 90px; flex-shrink: 0; font-size: 0.82rem; }
        .data-value { color: var(--text); font-weight: 600; }
        .data-value.empty { color: var(--text-pale); font-weight: 400; font-style: italic; }
        .data-value.danger { color: #dc2626; }

        /* BP GRID */
        .bp-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.5rem;
        }
        .bp-cell {
            background: var(--bg);
            border-radius: 7px;
            padding: 0.6rem 0.75rem;
            border-left: 3px solid var(--blue-lt);
        }
        .bp-cell-label { font-size: 0.72rem; color: var(--text-sub); margin-bottom: 0.2rem; }
        .bp-cell-val { font-size: 0.95rem; font-weight: 700; color: var(--text); }
        .bp-cell-val.danger { color: #dc2626; }
        .bp-avg {
            margin-top: 0.6rem;
            background: #eff6ff;
            border-radius: 7px;
            padding: 0.5rem 0.85rem;
            text-align: center;
            font-size: 0.85rem;
            color: var(--navy);
        }

        /* MEAL GRID */
        .meal-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 0.6rem;
        }
        .meal-cell {
            background: #fefce8;
            border: 1px solid #fde68a;
            border-radius: 8px;
            padding: 0.65rem 0.85rem;
        }
        .meal-cell-title { font-size: 0.82rem; font-weight: 700; color: #92400e; margin-bottom: 0.4rem; }
        .meal-cell-item { font-size: 0.82rem; color: #78350f; line-height: 1.7; }

        /* BUTTONS */
        .action-row {
            display: flex;
            gap: 0.75rem;
            justify-content: center;
            margin-top: 1.25rem;
            flex-wrap: wrap;
        }
        .btn-action {
            padding: 0.65rem 1.5rem;
            border: none;
            border-radius: 8px;
            font-size: 0.88rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            transition: all 0.15s;
        }
        .btn-confirm { background: var(--navy); color: white; }
        .btn-confirm:hover { background: var(--navy-mid); color: white; }
        .btn-edit { background: var(--surface); color: var(--text-sub); border: 1.5px solid var(--border); }
        .btn-edit:hover { background: var(--bg); color: var(--text); text-decoration: none; }

        @@keyframes shake {
            0%,100% { transform: translateX(0); }
            20%,60% { transform: translateX(-4px); }
            40%,80% { transform: translateX(4px); }
        }

        @@media (max-width: 600px) {
            .topbar { padding: 0 1rem; }
            .hero { padding: 1.25rem; }
            .main-container { padding: 0 0.85rem; }
            .bp-grid { grid-template-columns: 1fr 1fr; }
            .action-row { flex-direction: column-reverse; }
            .btn-action { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>

<header class="topbar">
    <div class="topbar-logo">
        <div class="cross">✚</div>
        代謝症候群疾病管理與追蹤系統
    </div>
</header>

<div class="hero">
    <div class="hero-title"><i class="bi bi-check-circle"></i> 請確認您的資料</div>
    <div class="hero-sub">@Model.RecordDate.ToString("yyyy 年 MM 月 dd 日")</div>
</div>

<div class="main-container">

    @{
        var warnings = new List<string>();
        var allSystolic  = new[] { Model.BP_First_1_Systolic,  Model.BP_First_2_Systolic,
                                   Model.BP_Second_1_Systolic, Model.BP_Second_2_Systolic }
                           .Where(v => v.HasValue).Select(v => v.Value);
        var allDiastolic = new[] { Model.BP_First_1_Diastolic,  Model.BP_First_2_Diastolic,
                                   Model.BP_Second_1_Diastolic, Model.BP_Second_2_Diastolic }
                           .Where(v => v.HasValue).Select(v => v.Value);
        if (allSystolic.Any(v => v > 200))   warnings.Add("收縮壓 >200 mmHg，請確認是否輸入錯誤");
        if (allDiastolic.Any(v => v > 160))  warnings.Add("舒張壓 >160 mmHg，請確認是否輸入錯誤");
        if (Model.BloodSugar.HasValue  && Model.BloodSugar.Value > 300)      warnings.Add("血糖 >300 mg/dL，請確認是否輸入錯誤");
        if (Model.ExerciseDuration.HasValue && Model.ExerciseDuration.Value > 720) warnings.Add("運動時間 >720 分鐘，請確認是否輸入錯誤");
        if (Model.WaterIntake.HasValue && Model.WaterIntake.Value > 5000)    warnings.Add("飲水量 >5000 ml，請確認是否輸入錯誤");
        if (Model.Cigarettes.HasValue  && Model.Cigarettes.Value > 50)       warnings.Add("抽菸數 >50 支，請確認是否輸入錯誤");
        if (Model.BetelNut.HasValue    && Model.BetelNut.Value > 50)         warnings.Add("嚼檳榔 >50 次，請確認是否輸入錯誤");
    }

    @if (warnings.Any())
    {
        <div class="warn-box" style="animation: shake 0.5s;">
            <div class="warn-title"><i class="bi bi-exclamation-triangle-fill"></i> 數值可能有誤</div>
            @foreach (var w in warnings)
            {
                <div class="warn-item">❌ @w</div>
            }
            <div class="warn-hint">如有誤請點擊下方「需要修改」返回修改。</div>
        </div>
    }

    <!-- 血壓 -->
    @if (Model.BP_First_1_Systolic.HasValue || Model.BP_First_1_Diastolic.HasValue ||
         Model.BP_First_2_Systolic.HasValue || Model.BP_First_2_Diastolic.HasValue ||
         Model.BP_Second_1_Systolic.HasValue || Model.BP_Second_1_Diastolic.HasValue ||
         Model.BP_Second_2_Systolic.HasValue || Model.BP_Second_2_Diastolic.HasValue)
    {
        <div class="card">
            <div class="card-header">❤️ 血壓測量</div>
            <div class="card-body">
                <div class="bp-grid">
                    @{
                        var bpItems = new[]
                        {
                            ("上午第一遍", Model.BP_First_1_Systolic,  Model.BP_First_1_Diastolic),
                            ("上午第二遍", Model.BP_First_2_Systolic,  Model.BP_First_2_Diastolic),
                            ("睡前第一遍", Model.BP_Second_1_Systolic, Model.BP_Second_1_Diastolic),
                            ("睡前第二遍", Model.BP_Second_2_Systolic, Model.BP_Second_2_Diastolic),
                        };
                    }
                    @foreach (var (label, sys, dia) in bpItems)
                    {
                        var isDanger = (sys.HasValue && sys > 200) || (dia.HasValue && dia > 160);
                        <div class="bp-cell">
                            <div class="bp-cell-label">@label</div>
                            @if (sys.HasValue && dia.HasValue)
                            {
                                <div class="bp-cell-val @(isDanger ? "danger" : "")">
                                    @sys.Value.ToString("0") / @dia.Value.ToString("0") <small style="font-weight:400;font-size:0.72rem;">mmHg</small>
                                </div>
                            }
                            else
                            {
                                <div class="bp-cell-val" style="color:var(--text-pale);font-weight:400;font-size:0.82rem;">未填寫</div>
                            }
                        </div>
                    }
                </div>
                @if (Model.AvgSystolicBP.HasValue && Model.AvgDiastolicBP.HasValue)
                {
                    <div class="bp-avg">
                        平均血壓：<strong>@Model.AvgSystolicBP.Value.ToString("0") / @Model.AvgDiastolicBP.Value.ToString("0") mmHg</strong>
                    </div>
                }
            </div>
        </div>
    }

    <!-- 三餐 -->
    @if (Model.Meals_Breakfast != null || Model.Meals_Lunch != null || Model.Meals_Dinner != null)
    {
        <div class="card">
            <div class="card-header">🍽️ 三餐攝取</div>
            <div class="card-body">
                <div class="meal-grid">
                    @if (Model.Meals_Breakfast != null)
                    {
                        <div class="meal-cell">
                            <div class="meal-cell-title">🌅 早餐</div>
                            <div class="meal-cell-item">
                                @if (!string.IsNullOrEmpty(Model.Meals_Breakfast.Vegetables))  { <div>🥬 蔬菜：@Model.Meals_Breakfast.Vegetables</div> }
                                @if (!string.IsNullOrEmpty(Model.Meals_Breakfast.Protein))     { <div>🥩 蛋白質：@Model.Meals_Breakfast.Protein</div> }
                                @if (!string.IsNullOrEmpty(Model.Meals_Breakfast.Carbs))       { <div>🍚 澱粉：@Model.Meals_Breakfast.Carbs</div> }
                            </div>
                        </div>
                    }
                    @if (Model.Meals_Lunch != null)
                    {
                        <div class="meal-cell">
                            <div class="meal-cell-title">☀️ 午餐</div>
                            <div class="meal-cell-item">
                                @if (!string.IsNullOrEmpty(Model.Meals_Lunch.Vegetables)) { <div>🥬 蔬菜：@Model.Meals_Lunch.Vegetables</div> }
                                @if (!string.IsNullOrEmpty(Model.Meals_Lunch.Protein))    { <div>🥩 蛋白質：@Model.Meals_Lunch.Protein</div> }
                                @if (!string.IsNullOrEmpty(Model.Meals_Lunch.Carbs))      { <div>🍚 澱粉：@Model.Meals_Lunch.Carbs</div> }
                            </div>
                        </div>
                    }
                    @if (Model.Meals_Dinner != null)
                    {
                        <div class="meal-cell">
                            <div class="meal-cell-title">🌙 晚餐</div>
                            <div class="meal-cell-item">
                                @if (!string.IsNullOrEmpty(Model.Meals_Dinner.Vegetables)) { <div>🥬 蔬菜：@Model.Meals_Dinner.Vegetables</div> }
                                @if (!string.IsNullOrEmpty(Model.Meals_Dinner.Protein))    { <div>🥩 蛋白質：@Model.Meals_Dinner.Protein</div> }
                                @if (!string.IsNullOrEmpty(Model.Meals_Dinner.Carbs))      { <div>🍚 澱粉：@Model.Meals_Dinner.Carbs</div> }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- 運動 + 飲品 + 習慣 + 血糖 (合一張卡) -->
    @{
        bool hasOther = !string.IsNullOrEmpty(Model.ExerciseType) || Model.ExerciseDuration.HasValue
                     || Model.WaterIntake.HasValue || !string.IsNullOrEmpty(Model.Beverage)
                     || Model.Cigarettes.HasValue || Model.BetelNut.HasValue || Model.BloodSugar.HasValue;
    }
    @if (hasOther)
    {
        <div class="card">
            <div class="card-header"><i class="bi bi-clipboard-data"></i> 其他健康資訊</div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.ExerciseType) || Model.ExerciseDuration.HasValue)
                {
                    <div class="data-row">
                        <span class="data-label">🏃 運動種類</span>
                        <span class="data-value @(string.IsNullOrEmpty(Model.ExerciseType) ? "empty" : "")">@(Model.ExerciseType ?? "未填寫")</span>
                    </div>
                    <div class="data-row">
                        <span class="data-label">🏃 運動時間</span>
                        <span class="data-value @(!Model.ExerciseDuration.HasValue ? "empty" : "") @(Model.ExerciseDuration > 720 ? "danger" : "")">
                            @(Model.ExerciseDuration.HasValue ? $"{Model.ExerciseDuration.Value:0.0} 分鐘" : "未填寫")
                        </span>
                    </div>
                }
                @if (Model.WaterIntake.HasValue)
                {
                    <div class="data-row">
                        <span class="data-label">💧 飲水量</span>
                        <span class="data-value @(Model.WaterIntake > 5000 ? "danger" : "")">@Model.WaterIntake.Value.ToString("0") ml</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Beverage))
                {
                    <div class="data-row">
                        <span class="data-label">🥤 其他飲料</span>
                        <span class="data-value">@Model.Beverage</span>
                    </div>
                }
                @if (Model.Cigarettes.HasValue)
                {
                    <div class="data-row">
                        <span class="data-label">🚬 抽菸</span>
                        <span class="data-value @(Model.Cigarettes > 50 ? "danger" : "")">@Model.Cigarettes.Value.ToString("0") 支</span>
                    </div>
                }
                @if (Model.BetelNut.HasValue)
                {
                    <div class="data-row">
                        <span class="data-label">🌿 檳榔</span>
                        <span class="data-value @(Model.BetelNut > 50 ? "danger" : "")">@Model.BetelNut.Value.ToString("0") 次</span>
                    </div>
                }
                @if (Model.BloodSugar.HasValue)
                {
                    <div class="data-row">
                        <span class="data-label">🩸 血糖</span>
                        <span class="data-value @(Model.BloodSugar > 300 ? "danger" : "")">@Model.BloodSugar.Value.ToString("0.0") mg/dL</span>
                    </div>
                }
            </div>
        </div>
    }

    <!-- 確認表單 -->
    <form id="confirmForm" asp-controller="DailyHealth"
          asp-action="@(Model.Id > 0 ? "ConfirmUpdate" : "ConfirmSubmit")" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="RecordDate" value="@Model.RecordDate.ToString("yyyy-MM-ddTHH:mm:ss")" />
        <input type="hidden" asp-for="RecordTime" value="@Model.RecordTime?.ToString()" />
        <input type="hidden" asp-for="BP_First_1_Systolic" />
        <input type="hidden" asp-for="BP_First_1_Diastolic" />
        <input type="hidden" asp-for="BP_First_2_Systolic" />
        <input type="hidden" asp-for="BP_First_2_Diastolic" />
        <input type="hidden" asp-for="BP_Second_1_Systolic" />
        <input type="hidden" asp-for="BP_Second_1_Diastolic" />
        <input type="hidden" asp-for="BP_Second_2_Systolic" />
        <input type="hidden" asp-for="BP_Second_2_Diastolic" />
        @if (Model.Meals_Breakfast != null)
        {
            <input type="hidden" name="Meals_Breakfast" value="@System.Text.Json.JsonSerializer.Serialize(Model.Meals_Breakfast)" />
        }
        @if (Model.Meals_Lunch != null)
        {
            <input type="hidden" name="Meals_Lunch" value="@System.Text.Json.JsonSerializer.Serialize(Model.Meals_Lunch)" />
        }
        @if (Model.Meals_Dinner != null)
        {
            <input type="hidden" name="Meals_Dinner" value="@System.Text.Json.JsonSerializer.Serialize(Model.Meals_Dinner)" />
        }
        <input type="hidden" asp-for="ExerciseType" />
        <input type="hidden" asp-for="ExerciseDuration" />
        <input type="hidden" asp-for="WaterIntake" />
        <input type="hidden" asp-for="Beverage" />
        <input type="hidden" asp-for="Cigarettes" />
        <input type="hidden" asp-for="BetelNut" />
        <input type="hidden" asp-for="BloodSugar" />

        <div class="action-row">
            <button type="button" onclick="goBackToEdit()" class="btn-action btn-edit">
                <i class="bi bi-pencil"></i> 需要修改
            </button>
            <button type="submit" class="btn-action btn-confirm">
                <i class="bi bi-check-lg"></i> 確認上傳
            </button>
        </div>
    </form>

</div>

<script>
    function goBackToEdit() {
        const form = document.getElementById('confirmForm');
        const editForm = document.createElement('form');
        editForm.method = 'GET';

        if (@Model.Id === 0) {
            editForm.action = '@Url.Action("Create", "DailyHealth")';
            form.querySelectorAll('input[type="hidden"]').forEach(input => {
                if (input.name && input.name !== '__RequestVerificationToken' && input.value) {
                    const el = document.createElement('input');
                    el.type = 'hidden';
                    el.name = input.name;
                    el.value = input.value;
                    editForm.appendChild(el);
                }
            });
        } else {
            editForm.action = '@Url.Action("Edit", "DailyHealth", new { id = Model.Id })';
        }

        document.body.appendChild(editForm);
        editForm.submit();
    }
</script>
</body>
</html>
