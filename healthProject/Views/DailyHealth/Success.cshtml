@model FeedbackViewModel
@{
    ViewData["Title"] = "上傳成功";
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --navy:     #0a2540;
            --navy-mid: #103a5e;
            --blue:     #1a6fb5;
            --blue-lt:  #2589d8;
            --bg:       #f4f6f9;
            --surface:  #ffffff;
            --border:   #dde3ea;
            --text:     #1a2635;
            --text-sub: #5a6a7e;
            --text-pale:#8fa0b4;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            font-family: 'Noto Sans TC', 'Microsoft JhengHei', Arial, sans-serif;
            color: var(--text);
            min-height: 100vh;
        }

        /* TOP BAR */
        .topbar {
            background: var(--navy);
            height: 56px;
            display: flex;
            align-items: center;
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 12px rgba(0,0,0,0.25);
        }

        .topbar-logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            color: white;
            font-weight: 700;
            font-size: 1rem;
        }

        .cross {
            width: 28px; height: 28px;
            background: var(--blue-lt);
            border-radius: 6px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; font-weight: 900; color: white;
        }

        /* HERO */
        .hero {
            background: linear-gradient(100deg, var(--navy-mid) 0%, var(--blue) 100%);
            padding: 2.5rem 2.5rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .hero::after {
            content: '';
            position: absolute;
            right: -60px; top: -60px;
            width: 240px; height: 240px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
            pointer-events: none;
        }

        .success-icon {
            font-size: 3rem;
            margin-bottom: 0.75rem;
            animation: bounce 0.8s ease;
            display: block;
        }

        @@keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-14px); }
        }

        .hero-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: white;
            margin-bottom: 0.3rem;
        }

        .hero-sub {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.6);
        }

        /* MAIN */
        .main-container {
            max-width: 720px;
            margin: 1.75rem auto;
            padding: 0 1.5rem;
        }

        /* FEEDBACK CARDS */
        .feedback-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            margin-bottom: 1.75rem;
        }

        .feedback-card {
            background: var(--surface);
            border-radius: 10px;
            border: 1px solid var(--border);
            border-left: 4px solid var(--border);
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
            padding: 1rem 1.25rem;
            display: flex;
            align-items: flex-start;
            gap: 0.85rem;
        }

        .feedback-card.success { border-left-color: #2e7d32; }
        .feedback-card.warning { border-left-color: #e67e22; }
        .feedback-card.info    { border-left-color: var(--blue); }
        .feedback-card.danger  { border-left-color: #c0392b; }

        .feedback-card.success { background: #f0fdf4; }
        .feedback-card.warning { background: #fffbeb; }
        .feedback-card.info    { background: #eff6ff; }
        .feedback-card.danger  { background: #fef2f2; }

        .feedback-emoji {
            font-size: 1.4rem;
            flex-shrink: 0;
            margin-top: 0.05rem;
        }

        .feedback-text {
            font-size: 0.9rem;
            line-height: 1.6;
            color: var(--text);
        }

        /* ACTION BUTTONS */
        .action-row {
            display: flex;
            gap: 0.75rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-action {
            padding: 0.65rem 1.5rem;
            border: none;
            border-radius: 8px;
            font-size: 0.88rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            transition: all 0.15s;
        }

        .btn-primary {
            background: var(--navy);
            color: white;
        }
        .btn-primary:hover { background: var(--navy-mid); color: white; text-decoration: none; }

        .btn-secondary {
            background: var(--surface);
            color: var(--text-sub);
            border: 1.5px solid var(--border);
        }
        .btn-secondary:hover { background: var(--bg); color: var(--text); text-decoration: none; }

        @@media (max-width: 600px) {
            .topbar { padding: 0 1rem; }
            .hero { padding: 2rem 1.25rem 1.75rem; }
            .main-container { padding: 0 1rem; }
            .action-row { flex-direction: column; }
            .btn-action { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>

<header class="topbar">
    <div class="topbar-logo">
        <div class="cross">✚</div>
        代謝症候群疾病管理與追蹤系統
    </div>
</header>

<div class="hero">
    <span class="success-icon">🎉</span>
    <div class="hero-title">上傳成功！</div>
    <div class="hero-sub">您的今日健康資訊已成功記錄</div>
</div>

<div class="main-container">

    <div class="feedback-list">

        @if (!string.IsNullOrEmpty(Model.WaterMessage))
        {
            <div class="feedback-card @Model.WaterStatus">
                <span class="feedback-emoji">💧</span>
                <div class="feedback-text">@Model.WaterMessage</div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.ExerciseMessage))
        {
            <div class="feedback-card @Model.ExerciseStatus">
                <span class="feedback-emoji">🏃</span>
                <div class="feedback-text">@Model.ExerciseMessage</div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.CigaretteMessage))
        {
            <div class="feedback-card @Model.CigaretteStatus">
                <span class="feedback-emoji">🚭</span>
                <div class="feedback-text">@Model.CigaretteMessage</div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.BloodPressureMessage))
        {
            <div class="feedback-card @Model.BloodPressureStatus">
                <span class="feedback-emoji">❤️</span>
                <div class="feedback-text">@Model.BloodPressureMessage</div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.BloodSugarMessage))
        {
            <div class="feedback-card @Model.BloodSugarStatus">
                <span class="feedback-emoji">🩸</span>
                <div class="feedback-text">@Model.BloodSugarMessage</div>
            </div>
        }

    </div>

    <div class="action-row">
        <a href="@Url.Action("MyRecords", "DailyHealth")" class="btn-action btn-secondary">
            <i class="bi bi-clock-history"></i> 查看我的紀錄
        </a>
        <a href="@Url.Action("Index", "DailyHealth")" class="btn-action btn-primary">
            <i class="bi bi-house"></i> 回到首頁
        </a>
    </div>

</div>

</body>
</html>
