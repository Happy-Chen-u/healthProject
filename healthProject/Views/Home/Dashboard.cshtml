@{
    ViewData["Title"] = "系統功能選單";
    Layout = null;
    var userName = User.FindFirst("FullName")?.Value ?? User.Identity.Name;
    var isAdmin = User.IsInRole("Admin");
    var now = DateTime.Now;
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --navy:      #0a2540;
            --navy-mid:  #103a5e;
            --blue:      #1a6fb5;
            --blue-lt:   #2589d8;
            --teal:      #0e8a7a;
            --teal-lt:   #12a694;
            --red:       #c0392b;
            --red-lt:    #e74c3c;
            --amber:     #e67e22;
            --bg:        #f4f6f9;
            --surface:   #ffffff;
            --border:    #dde3ea;
            --text:      #1a2635;
            --text-sub:  #5a6a7e;
            --text-pale: #8fa0b4;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Noto Sans TC', 'Microsoft JhengHei', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── TOP BAR ── */
        .topbar {
            background: var(--navy);
            height: 56px;
            display: flex;
            align-items: center;
            padding: 0 2rem;
            gap: 1rem;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 12px rgba(0,0,0,0.25);
        }

        .topbar-logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            color: white;
            font-weight: 700;
            font-size: 1rem;
            letter-spacing: 0.02em;
            text-decoration: none;
        }

        .topbar-logo .cross {
            width: 28px; height: 28px;
            background: var(--blue-lt);
            border-radius: 6px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem;
        }

        .topbar-divider {
            width: 1px; height: 24px;
            background: rgba(255,255,255,0.15);
            margin: 0 0.25rem;
        }

        .topbar-system {
            color: rgba(255,255,255,0.55);
            font-size: 0.8rem;
            font-weight: 400;
        }

        .topbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 1.25rem;
        }

        .topbar-time {
            color: rgba(255,255,255,0.6);
            font-size: 0.78rem;
            font-variant-numeric: tabular-nums;
        }

        .topbar-user {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: white;
            font-size: 0.85rem;
        }

        .user-avatar {
            width: 32px; height: 32px;
            background: var(--blue-lt);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.8rem; font-weight: 700;
        }

        .role-pill {
            background: rgba(255,255,255,0.12);
            color: rgba(255,255,255,0.75);
            font-size: 0.7rem;
            padding: 0.15rem 0.55rem;
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.15);
        }

        .topbar-btn {
            color: rgba(255,255,255,0.65);
            background: none;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 6px;
            padding: 0.3rem 0.75rem;
            font-size: 0.78rem;
            cursor: pointer;
            transition: all 0.2s;
            display: flex; align-items: center; gap: 0.35rem;
        }
        .topbar-btn:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        /* ── MAIN LAYOUT ── */
        .page-body {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        /* ── HERO STRIP ── */
        .hero {
            background: linear-gradient(100deg, var(--navy-mid) 0%, var(--blue) 100%);
            padding: 2rem 2.5rem 1.75rem;
            position: relative;
            overflow: hidden;
        }

        .hero::after {
            content: '';
            position: absolute;
            right: -60px; top: -60px;
            width: 280px; height: 280px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
            pointer-events: none;
        }

        .hero::before {
            content: '';
            position: absolute;
            right: 80px; bottom: -80px;
            width: 180px; height: 180px;
            border-radius: 50%;
            background: rgba(255,255,255,0.03);
            pointer-events: none;
        }

        .hero-greeting {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.55);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 0.3rem;
        }

        .hero-name {
            font-size: 1.6rem;
            font-weight: 700;
            color: white;
            margin-bottom: 0.5rem;
        }

        .hero-meta {
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .hero-tag {
            background: rgba(255,255,255,0.12);
            color: rgba(255,255,255,0.85);
            font-size: 0.78rem;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.18);
            display: flex; align-items: center; gap: 0.3rem;
        }

        .hero-date {
            color: rgba(255,255,255,0.45);
            font-size: 0.78rem;
        }

        /* ── MAIN CONTENT ── */
        .content {
            padding: 2rem 2.5rem;
            flex: 1;
        }

        .section-label {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--text-pale);
            margin-bottom: 1rem;
        }

        /* ── NAV GRID ── */
        .nav-grid {
            display: grid;
            gap: 1px;
            background: var(--border);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 2rem;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }

        .nav-item {
            background: var(--surface);
            padding: 1.5rem 1.25rem;
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
            text-decoration: none;
            color: var(--text);
            transition: background 0.15s;
            position: relative;
            cursor: pointer;
        }

        .nav-item:hover {
            background: #f0f5ff;
            text-decoration: none;
            color: var(--text);
        }

        .nav-item:hover .nav-arrow {
            opacity: 1;
            transform: translateX(0);
        }

        .nav-item-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
        }

        .nav-icon {
            width: 40px; height: 40px;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .nav-arrow {
            color: var(--text-pale);
            font-size: 0.9rem;
            opacity: 0;
            transform: translateX(-4px);
            transition: all 0.2s;
            margin-top: 2px;
        }

        .nav-title {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 0.15rem;
        }

        .nav-desc {
            font-size: 0.78rem;
            color: var(--text-sub);
            line-height: 1.5;
        }

        /* 顏色主題 */
        .theme-blue  .nav-icon { background: #e8f1fb; color: var(--blue); }
        .theme-teal  .nav-icon { background: #e5f5f3; color: var(--teal); }
        .theme-indigo .nav-icon { background: #eceffe; color: #4a57c8; }
        .theme-green .nav-icon { background: #e8f5e9; color: #2e7d32; }
        .theme-red   .nav-icon { background: #fdecea; color: var(--red); }
        .theme-amber .nav-icon { background: #fef3e2; color: var(--amber); }

        .theme-blue:hover  { background: #f0f5fd !important; }
        .theme-teal:hover  { background: #f0faf8 !important; }
        .theme-indigo:hover { background: #f2f3fe !important; }
        .theme-green:hover { background: #f1f8f1 !important; }
        .theme-red:hover   { background: #fdf5f5 !important; }
        .theme-amber:hover { background: #fdf8f0 !important; }

        /* 警示徽章 */
        .alert-dot {
            position: absolute;
            top: 14px; right: 14px;
            background: var(--red-lt);
            color: white;
            font-size: 0.65rem;
            font-weight: 700;
            padding: 0.15rem 0.45rem;
            border-radius: 20px;
            letter-spacing: 0.03em;
            animation: badgePulse 2s ease-in-out infinite;
        }

        @@keyframes badgePulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(231,76,60,0.4); }
            50% { box-shadow: 0 0 0 5px rgba(231,76,60,0); }
        }

        /* 紅色警示卡 */
        .nav-item.alert-card {
            background: #fff8f8;
            border-left: 3px solid var(--red-lt);
        }
        .nav-item.alert-card:hover { background: #fdf0f0 !important; }
        .nav-item.alert-card .nav-title { color: var(--red); }

        /* ── BOTTOM BAR ── */
        .bottom-bar {
            padding: 1.25rem 2.5rem;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--surface);
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .bottom-links {
            display: flex;
            gap: 0.75rem;
        }

        .bottom-link {
            color: var(--text-sub);
            font-size: 0.8rem;
            text-decoration: none;
            display: flex; align-items: center; gap: 0.3rem;
            padding: 0.4rem 0.85rem;
            border-radius: 6px;
            border: 1px solid var(--border);
            transition: all 0.15s;
        }
        .bottom-link:hover {
            background: var(--bg);
            color: var(--text);
            text-decoration: none;
        }

        .logout-btn {
            background: none;
            border: 1px solid #e8d0cf;
            color: var(--red);
            font-size: 0.8rem;
            padding: 0.4rem 0.85rem;
            border-radius: 6px;
            cursor: pointer;
            display: flex; align-items: center; gap: 0.3rem;
            transition: all 0.15s;
        }
        .logout-btn:hover {
            background: #fdecea;
        }

        .copyright {
            font-size: 0.72rem;
            color: var(--text-pale);
        }

        /* ── SUCCESS MSG ── */
        .success-bar {
            background: #e8f5e9;
            border-left: 4px solid #4caf50;
            color: #2e7d32;
            padding: 0.7rem 1.5rem;
            font-size: 0.85rem;
            display: flex; align-items: center; gap: 0.5rem;
        }

        /* ── MODAL ── */
        .modal-overlay {
            display: none;
            position: fixed; inset: 0;
            background: rgba(10,37,64,0.5);
            z-index: 999;
            align-items: center;
            justify-content: center;
        }
        .modal-overlay.open { display: flex; }

        .modal-box {
            background: white;
            border-radius: 12px;
            padding: 2rem;
            width: 340px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        }

        .modal-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 0.5rem;
        }

        .modal-body {
            font-size: 0.9rem;
            color: var(--text-sub);
            margin-bottom: 1.5rem;
        }

        .modal-actions {
            display: flex; gap: 0.75rem; justify-content: flex-end;
        }

        .btn-cancel {
            padding: 0.5rem 1.25rem;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: white;
            color: var(--text-sub);
            font-size: 0.85rem;
            cursor: pointer;
        }

        .btn-confirm-logout {
            padding: 0.5rem 1.25rem;
            border-radius: 6px;
            border: none;
            background: var(--red);
            color: white;
            font-size: 0.85rem;
            cursor: pointer;
            font-family: inherit;
        }

        /* ── RESPONSIVE ── */
        @@media (max-width: 768px) {
            .topbar { padding: 0 1rem; }
            .topbar-system { display: none; }
            .topbar-time { display: none; }
            .hero { padding: 1.5rem 1.25rem; }
            .hero-name { font-size: 1.3rem; }
            .content { padding: 1.25rem; }
            .nav-grid {
                grid-template-columns: repeat(2, 1fr) !important;
            }
            .bottom-bar { padding: 1rem 1.25rem; }
        }

        @@media (max-width: 480px) {
            .nav-grid {
                grid-template-columns: 1fr !important;
            }
        }

        /* ── FADE IN ── */
        .nav-item {
            animation: fadeUp 0.3s ease both;
        }
        .nav-item:nth-child(1) { animation-delay: 0.05s; }
        .nav-item:nth-child(2) { animation-delay: 0.1s; }
        .nav-item:nth-child(3) { animation-delay: 0.15s; }
        .nav-item:nth-child(4) { animation-delay: 0.2s; }
        .nav-item:nth-child(5) { animation-delay: 0.25s; }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(8px); }
            to   { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

<!-- TOP BAR -->
<header class="topbar">
        <div class="topbar-logo">
            <div class="cross">✚</div>
            代謝症候群疾病管理與追蹤系統
        </div>

    <div class="topbar-right">
        <div class="topbar-user">
            <div class="user-avatar">@(userName?.Length > 0 ? userName[0].ToString() : "醫")</div>
            <span>@userName</span>
            <span class="role-pill">@(isAdmin ? "管理者" : "個案")</span>
        </div>
    </div>
</header>

<!-- SUCCESS MSG -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="success-bar">
        <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="page-body">

    <!-- HERO -->
    <div class="hero">
        <div class="hero-greeting">Welcome back</div>
        <div class="hero-name">@userName @(isAdmin ? "醫師" : "")</div>
        <div class="hero-meta">
            <span class="hero-tag">
                <i class="bi bi-shield-check"></i>
                @(isAdmin ? "系統管理者" : "個案帳號")
            </span>
            <span class="hero-date">@now.ToString("yyyy 年 M 月 d 日　dddd", new System.Globalization.CultureInfo("zh-TW"))</span>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="content">
        <div class="section-label">功能模組</div>

            @{
                var colCount = isAdmin ? 5 : 3;
            }
            <div class="nav-grid" style="grid-template-columns: repeat(@colCount, 1fr);">
            <!-- 疾病個管 -->
            <a href="@Url.Action("Index", "CaseManagement")" class="nav-item theme-blue">
                <div class="nav-item-header">
                    <div class="nav-icon"><i class="bi bi-clipboard2-pulse"></i></div>
                    <i class="bi bi-chevron-right nav-arrow"></i>
                </div>
                <div>
                    <div class="nav-title">疾病個管系統</div>
                    <div class="nav-desc">@(isAdmin ? "管理所有病患疾病紀錄" : "查看我的疾病管理紀錄")</div>
                </div>
            </a>

            <!-- 今日健康 -->
            <a href="@Url.Action("Index", "DailyHealth")" class="nav-item theme-teal">
                <div class="nav-item-header">
                    <div class="nav-icon"><i class="bi bi-activity"></i></div>
                    <i class="bi bi-chevron-right nav-arrow"></i>
                </div>
                <div>
                    <div class="nav-title">今日健康資訊</div>
                    <div class="nav-desc">@(isAdmin ? "查看所有病患健康數據" : "記錄與查看每日健康資訊")</div>
                </div>
            </a>

            <!-- 健康分析 -->
            <a href="@Url.Action("Index", "Analysis")" class="nav-item theme-indigo">
                <div class="nav-item-header">
                    <div class="nav-icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <i class="bi bi-chevron-right nav-arrow"></i>
                </div>
                <div>
                    <div class="nav-title">健康分析</div>
                    <div class="nav-desc">@(isAdmin ? "查看病患健康趨勢與統計分析" : "查看我的健康趨勢與報表")</div>
                </div>
            </a>

            @if (isAdmin)
            {
                <!-- 個案填寫狀況 -->
                <a href="@Url.Action("MissedRecordsStatus", "CaseManagement")"
                   class="nav-item @(ViewBag.HasMissedRecords == true ? "alert-card" : "theme-amber")">
                    @if (ViewBag.HasMissedRecords == true)
                    {
                        <span class="alert-dot">NEW</span>
                    }
                    <div class="nav-item-header">
                        <div class="nav-icon"><i class="bi bi-exclamation-triangle"></i></div>
                        <i class="bi bi-chevron-right nav-arrow"></i>
                    </div>
                    <div>
                        <div class="nav-title">個案填寫狀況</div>
                        <div class="nav-desc">查看未填寫健康資訊的個案</div>
                    </div>
                </a>

                <!-- 衛教管理 -->
                <a href="@Url.Action("Index", "Education")" class="nav-item theme-green">
                    <div class="nav-item-header">
                        <div class="nav-icon"><i class="bi bi-journal-medical"></i></div>
                        <i class="bi bi-chevron-right nav-arrow"></i>
                    </div>
                    <div>
                        <div class="nav-title">衛教內容管理</div>
                        <div class="nav-desc">管理每日推播給病患的衛教訊息</div>
                    </div>
                </a>
            }
        </div>
    </div>

    <!-- BOTTOM BAR -->
    <div class="bottom-bar">
        <div class="bottom-links">
            <a href="@Url.Action("ChangePassword", "Account")" class="bottom-link">
                <i class="bi bi-key"></i> 變更密碼
            </a>
        </div>
        <span class="copyright">© 2025 輔仁大學附設醫院　代謝症候群管理系統</span>
        <button class="logout-btn" onclick="openLogout()">
            <i class="bi bi-box-arrow-right"></i> 登出系統
        </button>
    </div>
</div>

<!-- LOGOUT MODAL -->
<div class="modal-overlay" id="logoutModal">
    <div class="modal-box">
        <div class="modal-title">確認登出</div>
        <div class="modal-body">確定要登出系統嗎？</div>
        <div class="modal-actions">
            <button class="btn-cancel" onclick="closeLogout()">取消</button>
            <form method="post" action="@Url.Action("Logout", "Account")" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-confirm-logout">確認登出</button>
            </form>
        </div>
    </div>
</div>

<script>
    // 登出 Modal
    function openLogout() {
        document.getElementById('logoutModal').classList.add('open');
    }
    function closeLogout() {
        document.getElementById('logoutModal').classList.remove('open');
    }
    document.getElementById('logoutModal').addEventListener('click', function(e) {
        if (e.target === this) closeLogout();
    });
</script>

</body>
</html>
