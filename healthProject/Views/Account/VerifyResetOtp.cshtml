@{
    ViewData["Title"] = "輸入驗證碼";
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>輸入驗證碼 — 代謝症候群疾病管理與追蹤系統</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --navy: #0a2540;
            --navy-mid: #103a5e;
            --blue: #1a6fb5;
            --blue-lt: #2589d8;
            --bg: #f4f6f9;
            --surface: #ffffff;
            --border: #dde3ea;
            --text: #1a2635;
            --text-sub: #5a6a7e;
            --text-pale: #8fa0b4;
            --danger: #c0392b;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            min-height: 100%;
            font-family: 'Noto Sans TC', 'Microsoft JhengHei', sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        /* ── TOP BAR ── */
        .topbar {
            background: var(--navy);
            height: 56px;
            display: flex;
            align-items: center;
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 12px rgba(0,0,0,0.25);
        }

        .topbar-logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            color: white;
            font-weight: 700;
            font-size: 1rem;
        }

        .cross {
            width: 28px;
            height: 28px;
            background: var(--blue-lt);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            font-weight: 900;
            color: white;
        }

        .topbar-right {
            margin-left: auto;
        }

        .topbar-back {
            color: rgba(255,255,255,0.65);
            background: none;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 6px;
            padding: 0.3rem 0.85rem;
            font-size: 0.8rem;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.35rem;
            transition: all 0.2s;
        }

            .topbar-back:hover {
                background: rgba(255,255,255,0.1);
                color: white;
                text-decoration: none;
            }

        /* ── PAGE BODY ── */
        .page-body {
            min-height: calc(100vh - 56px);
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 3rem 1.5rem;
        }

        /* ── FORM CARD ── */
        .form-card {
            background: var(--surface);
            border-radius: 14px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
            border: 1px solid var(--border);
            width: 100%;
            max-width: 460px;
            overflow: hidden;
        }

        .card-header {
            background: linear-gradient(100deg, var(--navy-mid) 0%, var(--blue) 100%);
            padding: 1.75rem 2rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .card-header-icon {
            width: 44px;
            height: 44px;
            background: rgba(255,255,255,0.15);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: white;
            flex-shrink: 0;
        }

        .card-header-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: white;
            margin-bottom: 0.15rem;
        }

        .card-header-sub {
            font-size: 0.78rem;
            color: rgba(255,255,255,0.6);
        }

        /* ── FORM BODY ── */
        .card-body {
            padding: 1.75rem 2rem;
        }

        /* 說明提示 */
        .info-strip {
            background: #e8f1fb;
            border: 1px solid #c5d9f0;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: flex-start;
            gap: 0.6rem;
            font-size: 0.82rem;
            color: var(--blue);
            line-height: 1.6;
        }

            .info-strip i {
                margin-top: 0.1rem;
                flex-shrink: 0;
            }

        /* 錯誤訊息 */
        .alert-error {
            background: #fdecea;
            border: 1px solid #f5c6c2;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-size: 0.83rem;
            color: var(--danger);
            margin-bottom: 1.25rem;
            display: flex;
            align-items: flex-start;
            gap: 0.5rem;
        }

        /* 欄位 */
        .field {
            margin-bottom: 1.15rem;
        }

        .field-label {
            display: block;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--text-sub);
            margin-bottom: 0.4rem;
        }

        .field-wrap {
            position: relative;
        }

        .field-icon {
            position: absolute;
            left: 0.9rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-pale);
            font-size: 0.9rem;
            pointer-events: none;
        }

        .field-input {
            width: 100%;
            padding: 0.72rem 0.9rem 0.72rem 2.5rem;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: 0.9rem;
            font-family: inherit;
            color: var(--text);
            background: var(--surface);
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

            .field-input:focus {
                border-color: var(--blue-lt);
                box-shadow: 0 0 0 3px rgba(37,137,216,0.12);
            }

            .field-input::placeholder {
                color: var(--text-pale);
            }

        .field-error {
            font-size: 0.75rem;
            color: var(--danger);
            margin-top: 0.3rem;
        }

        /* 按鈕 */
        .btn-row {
            display: flex;
            gap: 0.75rem;
            margin-top: 1.5rem;
        }

        .btn-cancel {
            flex: 1;
            padding: 0.75rem;
            background: var(--surface);
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: 0.88rem;
            font-weight: 600;
            color: var(--text-sub);
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.35rem;
            transition: background 0.15s;
        }

            .btn-cancel:hover {
                background: var(--bg);
                text-decoration: none;
                color: var(--text-sub);
            }

        .btn-submit {
            flex: 2;
            padding: 0.75rem;
            background: var(--navy);
            border: none;
            border-radius: 8px;
            font-size: 0.88rem;
            font-weight: 600;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.35rem;
            transition: background 0.15s;
            font-family: inherit;
            cursor: pointer;
        }

            .btn-submit:hover {
                background: var(--navy-mid);
            }

        /* 底部 */
        .card-foot {
            padding: 1rem 2rem;
            border-top: 1px solid var(--border);
            background: var(--bg);
            font-size: 0.75rem;
            color: var(--text-pale);
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        @@media (max-width: 600px) {
            .topbar {
                padding: 0 1rem;
            }

            .page-body {
                padding: 1.5rem 1rem;
            }

            .card-body {
                padding: 1.5rem 1.25rem;
            }

            .card-header {
                padding: 1.25rem;
            }

            .card-foot {
                padding: 0.85rem 1.25rem;
            }
        }
    </style>
</head>
<body>

    <header class="topbar">
        <div class="topbar-logo">
            <div class="cross">✚</div>
            代謝症候群疾病管理與追蹤系統
        </div>
        <div class="topbar-right">
            <a href="@Url.Action("Login", "Account")" class="topbar-back">
                <i class="bi bi-arrow-left"></i> 返回登入
            </a>
        </div>
    </header>

    <div class="page-body">
        <div class="form-card">

            <div class="card-header">
                <div class="card-header-icon">
                    <i class="bi bi-envelope-check-fill"></i>
                </div>
                <div>
                    <div class="card-header-title">Email 驗證</div>
                    <div class="card-header-sub">請輸入寄送到您 Email 的驗證碼</div>
                </div>
            </div>

            <div class="card-body">

                <div class="info-strip">
                    <i class="bi bi-info-circle-fill"></i>
                    @if (ViewBag.MaskedEmail != null)
                    {
                        <span>驗證碼已寄送至 <strong>@ViewBag.MaskedEmail</strong>，請在 5 分鐘內輸入。</span>
                    }
                    else
                    {
                        <span>驗證碼已寄送至您的 Email，請在 5 分鐘內輸入。</span>
                    }
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-error">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }

                <form asp-action="VerifyResetOtp" method="post">
                    @Html.AntiForgeryToken()

                    <div class="field">
                        <label class="field-label">驗證碼</label>
                        <div class="field-wrap">
                            <i class="bi bi-shield-lock field-icon"></i>
                            <input type="text" name="otp" class="field-input"
                                   placeholder="請輸入 6 位數驗證碼"
                                   maxlength="6" inputmode="numeric"
                                   autocomplete="one-time-code"
                                   style="letter-spacing:0.3em; font-size:1.2rem; text-align:center;"
                                   autofocus />
                        </div>
                    </div>

                    <div class="btn-row">
                        <a href="@Url.Action("ForgotPassword", "Account")" class="btn-cancel">
                            <i class="bi bi-arrow-left"></i> 重新發送
                        </a>
                        <button type="submit" class="btn-submit">
                            <i class="bi bi-check-lg"></i> 驗證
                        </button>
                    </div>
                </form>
            </div>

            <div class="card-foot">
                <i class="bi bi-clock"></i>
                驗證碼有效期限為 5 分鐘，逾時請重新申請。
            </div>

        </div>
    </div>

</body>
</html>