@model ChangePasswordViewModel
@{
    ViewData["Title"] = "變更密碼";
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>變更密碼 — 代謝症候群疾病管理與追蹤系統</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --navy: #0a2540;
            --navy-mid: #103a5e;
            --blue: #1a6fb5;
            --blue-lt: #2589d8;
            --bg: #f4f6f9;
            --surface: #ffffff;
            --border: #dde3ea;
            --text: #1a2635;
            --text-sub: #5a6a7e;
            --text-pale: #8fa0b4;
            --danger: #c0392b;
            --success: #2e7d32;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            min-height: 100%;
            font-family: 'Noto Sans TC', 'Microsoft JhengHei', sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        /* ── TOP BAR ── */
        .topbar {
            background: var(--navy);
            height: 56px;
            display: flex;
            align-items: center;
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 12px rgba(0,0,0,0.25);
        }

        .topbar-logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            color: white;
            font-weight: 700;
            font-size: 1rem;
        }

        .cross {
            width: 28px;
            height: 28px;
            background: var(--blue-lt);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            font-weight: 900;
            color: white;
        }

        .topbar-right {
            margin-left: auto;
        }

        .topbar-back {
            color: rgba(255,255,255,0.65);
            background: none;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 6px;
            padding: 0.3rem 0.85rem;
            font-size: 0.8rem;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.35rem;
            transition: all 0.2s;
            font-family: inherit;
        }

            .topbar-back:hover {
                background: rgba(255,255,255,0.1);
                color: white;
                text-decoration: none;
            }

        /* ── PAGE BODY ── */
        .page-body {
            min-height: calc(100vh - 56px);
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 3rem 1.5rem;
        }

        /* ── FORM CARD ── */
        .form-card {
            background: var(--surface);
            border-radius: 14px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
            border: 1px solid var(--border);
            width: 100%;
            max-width: 480px;
            overflow: hidden;
        }

        .card-header {
            background: linear-gradient(100deg, var(--navy-mid) 0%, var(--blue) 100%);
            padding: 1.75rem 2rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .card-header-icon {
            width: 44px;
            height: 44px;
            background: rgba(255,255,255,0.15);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: white;
            flex-shrink: 0;
        }

        .card-header-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: white;
            margin-bottom: 0.15rem;
        }

        .card-header-sub {
            font-size: 0.78rem;
            color: rgba(255,255,255,0.6);
        }

        /* ── FORM BODY ── */
        .card-body {
            padding: 1.75rem 2rem;
        }

        /* 帳號資訊列 */
        .user-strip {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.75rem 1rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .user-strip-icon {
            width: 32px;
            height: 32px;
            background: var(--blue-lt);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 0.85rem;
            flex-shrink: 0;
        }

        .user-strip-label {
            font-size: 0.72rem;
            color: var(--text-pale);
        }

        .user-strip-value {
            font-size: 0.88rem;
            font-weight: 600;
            color: var(--text);
        }

        /* 訊息 */
        .alert {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-size: 0.83rem;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: flex-start;
            gap: 0.5rem;
            line-height: 1.5;
        }

        .alert-error {
            background: #fdecea;
            border: 1px solid #f5c6c2;
            color: var(--danger);
        }

        .alert-success {
            background: #e8f5e9;
            border: 1px solid #c8e6c9;
            color: var(--success);
        }

        /* 欄位 */
        .field {
            margin-bottom: 1.15rem;
        }

        .field-label {
            display: block;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--text-sub);
            margin-bottom: 0.4rem;
        }

        .field-wrap {
            position: relative;
        }

        .field-icon {
            position: absolute;
            left: 0.9rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-pale);
            font-size: 0.9rem;
            pointer-events: none;
        }

        .field-input {
            width: 100%;
            padding: 0.72rem 2.75rem 0.72rem 2.5rem;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: 0.9rem;
            font-family: inherit;
            color: var(--text);
            background: var(--surface);
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

            .field-input:focus {
                border-color: var(--blue-lt);
                box-shadow: 0 0 0 3px rgba(37,137,216,0.12);
            }

            .field-input.mismatch {
                border-color: var(--danger);
            }

            .field-input::placeholder {
                color: var(--text-pale);
            }

        .toggle-pw {
            position: absolute;
            right: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--text-pale);
            cursor: pointer;
            padding: 0.25rem;
            font-size: 0.88rem;
            transition: color 0.15s;
        }

            .toggle-pw:hover {
                color: var(--text-sub);
            }

        .field-error {
            font-size: 0.75rem;
            color: var(--danger);
            margin-top: 0.3rem;
        }

        /* 密碼要求 */
        .pw-rules {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.85rem 1rem;
            margin-bottom: 1.5rem;
        }

        .pw-rules-title {
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--text-sub);
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.35rem;
        }

        .pw-rule {
            font-size: 0.78rem;
            color: var(--text-pale);
            display: flex;
            align-items: center;
            gap: 0.4rem;
            margin-bottom: 0.25rem;
        }

            .pw-rule:last-child {
                margin-bottom: 0;
            }

            .pw-rule i {
                color: #4caf50;
                font-size: 0.7rem;
            }

        /* 按鈕 */
        .btn-row {
            display: flex;
            gap: 0.75rem;
            margin-top: 1.5rem;
        }

        .btn-cancel {
            flex: 1;
            padding: 0.75rem;
            background: var(--surface);
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: 0.88rem;
            font-weight: 600;
            color: var(--text-sub);
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.35rem;
            transition: background 0.15s;
            font-family: inherit;
            cursor: pointer;
        }

            .btn-cancel:hover {
                background: var(--bg);
                text-decoration: none;
                color: var(--text-sub);
            }

        .btn-save {
            flex: 2;
            padding: 0.75rem;
            background: var(--navy);
            border: none;
            border-radius: 8px;
            font-size: 0.88rem;
            font-weight: 600;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.35rem;
            transition: background 0.15s;
            font-family: inherit;
            cursor: pointer;
        }

            .btn-save:hover {
                background: var(--navy-mid);
            }

        /* 底部提示 */
        .card-foot {
            padding: 1rem 2rem;
            border-top: 1px solid var(--border);
            background: var(--bg);
            font-size: 0.75rem;
            color: var(--text-pale);
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        @@media (max-width: 600px) {
            .topbar {
                padding: 0 1rem;
            }

            .page-body {
                padding: 1.5rem 1rem;
            }

            .card-body {
                padding: 1.5rem 1.25rem;
            }

            .card-header {
                padding: 1.25rem;
            }

            .card-foot {
                padding: 0.85rem 1.25rem;
            }
        }
    </style>
</head>
<body>

    <!-- TOP BAR -->
    <header class="topbar">
        <div class="topbar-logo">
            <div class="cross">✚</div>
            代謝症候群疾病管理與追蹤系統
        </div>
        <div class="topbar-right">
            <a href="@Url.Action("Dashboard", "Home")" class="topbar-back">
                <i class="bi bi-arrow-left"></i> 返回選單
            </a>
        </div>
    </header>

    <div class="page-body">
        <div class="form-card">

            <!-- 卡片頁首 -->
            <div class="card-header">
                <div class="card-header-icon">
                    <i class="bi bi-key-fill"></i>
                </div>
                <div>
                    <div class="card-header-title">變更密碼</div>
                    <div class="card-header-sub">請輸入目前密碼及新密碼</div>
                </div>
            </div>

            <!-- 表單主體 -->
            <div class="card-body">

                <!-- 目前帳號 -->
                <div class="user-strip">
                    <div class="user-strip-icon">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <div>
                        <div class="user-strip-label">目前登入帳號</div>
                        <div class="user-strip-value">@User.Identity.Name</div>
                    </div>
                </div>

                <!-- 錯誤訊息 -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-error">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <!-- 成功訊息 -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle-fill"></i>
                        @TempData["SuccessMessage"]
                    </div>
                }

                <form asp-action="ChangePassword" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()

                    <!-- 目前密碼 -->
                    <div class="field">
                        <label asp-for="OldPassword" class="field-label">目前密碼</label>
                        <div class="field-wrap">
                            <i class="bi bi-lock field-icon"></i>
                            <input asp-for="OldPassword" type="password" id="oldPw"
                                   class="field-input" placeholder="請輸入目前密碼" autofocus />
                            <button type="button" class="toggle-pw" onclick="togglePw('oldPw','ic0')">
                                <i class="bi bi-eye" id="ic0"></i>
                            </button>
                        </div>
                        <span asp-validation-for="OldPassword" class="field-error"></span>
                    </div>

                    <!-- 新密碼 -->
                    <div class="field">
                        <label asp-for="NewPassword" class="field-label">新密碼</label>
                        <div class="field-wrap">
                            <i class="bi bi-lock field-icon"></i>
                            <input asp-for="NewPassword" type="password" id="newPw"
                                   class="field-input" placeholder="請輸入新密碼"
                                   oninput="checkMatch()" />
                            <button type="button" class="toggle-pw" onclick="togglePw('newPw','ic1')">
                                <i class="bi bi-eye" id="ic1"></i>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="field-error"></span>
                    </div>

                    <!-- 確認新密碼 -->
                    <div class="field">
                        <label asp-for="ConfirmPassword" class="field-label">確認新密碼</label>
                        <div class="field-wrap">
                            <i class="bi bi-lock field-icon"></i>
                            <input asp-for="ConfirmPassword" type="password" id="confirmPw"
                                   class="field-input" placeholder="請再次輸入新密碼"
                                   oninput="checkMatch()" />
                            <button type="button" class="toggle-pw" onclick="togglePw('confirmPw','ic2')">
                                <i class="bi bi-eye" id="ic2"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                    </div>

                    <!-- 密碼要求 -->
                    <div class="pw-rules">
                        <div class="pw-rules-title">
                            <i class="bi bi-info-circle"></i> 密碼要求
                        </div>
                        <div class="pw-rule">
                            <i class="bi bi-check-circle-fill"></i> 至少 6 個字元
                        </div>
                        <div class="pw-rule">
                            <i class="bi bi-check-circle-fill"></i> 新密碼與確認密碼必須相同
                        </div>
                    </div>

                    <!-- 按鈕 -->
                    <div class="btn-row">
                        <a href="@Url.Action("Dashboard", "Home")" class="btn-cancel">
                            <i class="bi bi-x"></i> 取消
                        </a>
                        <button type="submit" class="btn-save">
                            <i class="bi bi-check-lg"></i> 確認變更
                        </button>
                    </div>
                </form>
            </div>

            <!-- 底部提示 -->
            <div class="card-foot">
                <i class="bi bi-info-circle"></i>
                變更密碼後將自動登出，請重新登入。
            </div>

        </div>
    </div>

    <script>
        function togglePw(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }

        function checkMatch() {
            const nw = document.getElementById('newPw');
            const cf = document.getElementById('confirmPw');
            if (cf.value && nw.value !== cf.value) {
                cf.classList.add('mismatch');
            } else {
                cf.classList.remove('mismatch');
            }
        }
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
