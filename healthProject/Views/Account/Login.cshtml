@model LoginViewModel
@{
    ViewData["Title"] = "登入";
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>登入 — 代謝症候群疾病管理與追蹤系統</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --navy: #0a2540;
            --navy-mid: #103a5e;
            --blue: #1a6fb5;
            --blue-lt: #2589d8;
            --teal: #0e8a7a;
            --bg: #f4f6f9;
            --surface: #ffffff;
            --border: #dde3ea;
            --text: #1a2635;
            --text-sub: #5a6a7e;
            --text-pale: #8fa0b4;
            --danger: #c0392b;
            --success: #2e7d32;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            height: 100%;
            font-family: 'Noto Sans TC', 'Microsoft JhengHei', sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        /* ── LAYOUT ── */
        .page {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr;
        }

        @@media (min-width: 900px) {
            .page {
                grid-template-columns: 420px 1fr;
            }
        }

        /* ── LEFT PANEL ── */
        .left-panel {
            background: linear-gradient(160deg, var(--navy) 0%, var(--navy-mid) 55%, var(--blue) 100%);
            padding: 3rem 2.5rem;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            min-height: 280px;
        }

            .left-panel::before {
                content: '';
                position: absolute;
                width: 320px;
                height: 320px;
                border-radius: 50%;
                background: rgba(255,255,255,0.04);
                bottom: -100px;
                right: -80px;
                pointer-events: none;
            }

            .left-panel::after {
                content: '';
                position: absolute;
                width: 180px;
                height: 180px;
                border-radius: 50%;
                background: rgba(255,255,255,0.03);
                top: 60px;
                right: 40px;
                pointer-events: none;
            }

        .panel-logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            margin-bottom: auto;
        }

        .cross {
            width: 30px;
            height: 30px;
            background: var(--blue-lt);
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            font-weight: 900;
            color: white;
            flex-shrink: 0;
        }

        .panel-logo-text {
            font-size: 0.85rem;
            font-weight: 600;
            color: rgba(255,255,255,0.75);
            line-height: 1.3;
        }

        .panel-body {
            padding-top: 2.5rem;
        }

        .panel-eyebrow {
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.45);
            margin-bottom: 0.6rem;
        }

        .panel-title {
            font-size: 1.9rem;
            font-weight: 700;
            color: white;
            line-height: 1.25;
            margin-bottom: 1rem;
        }

        .panel-desc {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.55);
            line-height: 1.7;
            margin-bottom: 2.5rem;
        }

        .panel-features {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .panel-feature {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 0.82rem;
            color: rgba(255,255,255,0.65);
        }

        .pf-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--blue-lt);
            flex-shrink: 0;
        }

        .panel-footer {
            margin-top: auto;
            padding-top: 2rem;
            font-size: 0.72rem;
            color: rgba(255,255,255,0.3);
        }

        /* ── RIGHT PANEL ── */
        .right-panel {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem 2rem;
            background: var(--surface);
        }

        .form-card {
            width: 100%;
            max-width: 380px;
        }

        .form-header {
            margin-bottom: 2rem;
        }

        .form-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 0.3rem;
        }

        .form-subtitle {
            font-size: 0.85rem;
            color: var(--text-pale);
        }

        /* ── FORM ELEMENTS ── */
        .field {
            margin-bottom: 1.25rem;
        }

        .field-label {
            display: block;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--text-sub);
            margin-bottom: 0.45rem;
            letter-spacing: 0.02em;
        }

        .field-wrap {
            position: relative;
        }

        .field-icon {
            position: absolute;
            left: 0.9rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-pale);
            font-size: 0.95rem;
            pointer-events: none;
        }

        .field-input {
            width: 100%;
            padding: 0.72rem 0.9rem 0.72rem 2.5rem;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: 0.9rem;
            font-family: inherit;
            color: var(--text);
            background: var(--surface);
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

            .field-input:focus {
                border-color: var(--blue-lt);
                box-shadow: 0 0 0 3px rgba(37,137,216,0.12);
            }

            .field-input::placeholder {
                color: var(--text-pale);
            }

        .field-error {
            font-size: 0.75rem;
            color: var(--danger);
            margin-top: 0.3rem;
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

        .toggle-pw {
            position: absolute;
            right: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--text-pale);
            cursor: pointer;
            padding: 0.25rem;
            font-size: 0.9rem;
            line-height: 1;
            transition: color 0.15s;
        }

            .toggle-pw:hover {
                color: var(--text-sub);
            }

        .field-foot {
            display: flex;
            justify-content: flex-end;
            margin-top: 0.35rem;
        }

        .forgot-link {
            font-size: 0.78rem;
            color: var(--blue);
            text-decoration: none;
        }

            .forgot-link:hover {
                text-decoration: underline;
            }

        /* ── SUBMIT BTN ── */
        .btn-submit {
            width: 100%;
            padding: 0.8rem;
            background: var(--navy);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: background 0.2s, transform 0.15s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            margin-top: 1.5rem;
        }

            .btn-submit:hover {
                background: var(--navy-mid);
            }

            .btn-submit:active {
                transform: scale(0.99);
            }

        /* ── ALERTS ── */
        .alert {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-size: 0.83rem;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: flex-start;
            gap: 0.5rem;
            line-height: 1.5;
        }

        .alert-error {
            background: #fdecea;
            border: 1px solid #f5c6c2;
            color: var(--danger);
        }

        .alert-success {
            background: #e8f5e9;
            border: 1px solid #c8e6c9;
            color: var(--success);
        }

        /* ── FORM FOOTER ── */
        .form-foot {
            margin-top: 1.75rem;
            padding-top: 1.25rem;
            border-top: 1px solid var(--border);
            text-align: center;
        }

        .back-home {
            font-size: 0.8rem;
            color: var(--text-pale);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            transition: color 0.15s;
        }

            .back-home:hover {
                color: var(--text-sub);
            }

        /* ── RESPONSIVE ── */
        @@media (max-width: 899px) {
            .left-panel {
                padding: 2rem 1.5rem;
            }

            .panel-features {
                display: none;
            }

            .panel-body {
                padding-top: 1.5rem;
            }

            .panel-title {
                font-size: 1.5rem;
            }

            .panel-footer {
                display: none;
            }

            .right-panel {
                padding: 2.5rem 1.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="page">

        <!-- LEFT: BRANDING PANEL -->
        <div class="left-panel">
            <div class="panel-logo">
                <div class="cross">✚</div>
                <div class="panel-logo-text">輔仁大學附設醫院</div>
            </div>

            <div class="panel-body">
                <div class="panel-eyebrow">Medical Management System</div>
                <h1 class="panel-title">代謝症候群<br>疾病管理與<br>追蹤系統</h1>
                <p class="panel-desc">整合健康數據追蹤、病患個管與衛教推播的專業醫療管理平台。</p>

                <div class="panel-features">
                    <div class="panel-feature">
                        <div class="pf-dot"></div>
                        疾病個管與健康目標設定
                    </div>
                    <div class="panel-feature">
                        <div class="pf-dot"></div>
                        每日血壓、血糖、飲食記錄
                    </div>
                    <div class="panel-feature">
                        <div class="pf-dot"></div>
                        健康趨勢分析與 PDF 週報
                    </div>
                    <div class="panel-feature">
                        <div class="pf-dot"></div>
                        LINE Bot AI 智能資料輸入
                    </div>
                    <div class="panel-feature">
                        <div class="pf-dot"></div>
                        每日個人化衛教推播
                    </div>
                </div>
            </div>

            <div class="panel-footer">
                © 2025 輔仁大學附設醫院　代謝症候群管理系統
            </div>
        </div>

        <!-- RIGHT: LOGIN FORM -->
        <div class="right-panel">
            <div class="form-card">

                <div class="form-header">
                    <div class="form-title">登入系統</div>
                    <div class="form-subtitle">請輸入您的帳號與密碼以繼續</div>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle-fill"></i>
                        @TempData["SuccessMessage"]
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-error">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <form asp-action="Login" asp-controller="Account" method="post">
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                    <!-- 帳號 -->
                    <div class="field">
                        <label asp-for="Username" class="field-label">帳號（身分證字號）</label>
                        <div class="field-wrap">
                            <i class="bi bi-person field-icon"></i>
                            <input asp-for="Username" class="field-input"
                                   placeholder="例：A123456789" autofocus autocomplete="username" />
                        </div>
                        <span asp-validation-for="Username" class="field-error"></span>
                    </div>

                    <!-- 密碼 -->
                    <div class="field">
                        <label asp-for="Password" class="field-label">密碼</label>
                        <div class="field-wrap">
                            <i class="bi bi-lock field-icon"></i>
                            <input asp-for="Password" type="password" id="pwInput"
                                   class="field-input" placeholder="請輸入密碼"
                                   autocomplete="current-password" />
                            <button type="button" class="toggle-pw" onclick="togglePw()" id="pwToggle">
                                <i class="bi bi-eye" id="pwIcon"></i>
                            </button>
                        </div>
                        <div class="field-foot">
                            <a asp-controller="Account" asp-action="ForgotPassword" class="forgot-link">
                                忘記密碼？
                            </a>
                        </div>
                        <span asp-validation-for="Password" class="field-error"></span>
                    </div>

                    <button type="submit" class="btn-submit">
                        <i class="bi bi-box-arrow-in-right"></i>
                        登入
                    </button>
                </form>

                <div class="form-foot">
                    <a href="@Url.Action("Index", "Home")" class="back-home">
                        <i class="bi bi-arrow-left"></i> 返回首頁
                    </a>
                </div>

            </div>
        </div>

    </div>

    <script>
        function togglePw() {
            const input = document.getElementById('pwInput');
            const icon = document.getElementById('pwIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
