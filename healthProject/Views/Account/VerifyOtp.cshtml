@{
    ViewData["Title"] = "驗證碼驗證";
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>驗證碼驗證 — 代謝症候群疾病管理與追蹤系統</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --navy: #0a2540;
            --navy-mid: #103a5e;
            --blue: #1a6fb5;
            --blue-lt: #2589d8;
            --bg: #f4f6f9;
            --surface: #ffffff;
            --border: #dde3ea;
            --text: #1a2635;
            --text-sub: #5a6a7e;
            --text-pale: #8fa0b4;
            --danger: #c0392b;
            --success: #2e7d32;
            --amber: #e67e22;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            min-height: 100%;
            font-family: 'Noto Sans TC', 'Microsoft JhengHei', sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        /* ── TOP BAR ── */
        .topbar {
            background: var(--navy);
            height: 56px;
            display: flex;
            align-items: center;
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 12px rgba(0,0,0,0.25);
        }

        .topbar-logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            color: white;
            font-weight: 700;
            font-size: 1rem;
        }

        .cross {
            width: 28px;
            height: 28px;
            background: var(--blue-lt);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            font-weight: 900;
            color: white;
        }

        .topbar-right {
            margin-left: auto;
        }

        .topbar-back {
            color: rgba(255,255,255,0.65);
            background: none;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 6px;
            padding: 0.3rem 0.85rem;
            font-size: 0.8rem;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.35rem;
            transition: all 0.2s;
        }

            .topbar-back:hover {
                background: rgba(255,255,255,0.1);
                color: white;
                text-decoration: none;
            }

        /* ── PAGE BODY ── */
        .page-body {
            min-height: calc(100vh - 56px);
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 3rem 1.5rem;
        }

        /* ── FORM CARD ── */
        .form-card {
            background: var(--surface);
            border-radius: 14px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
            border: 1px solid var(--border);
            width: 100%;
            max-width: 460px;
            overflow: hidden;
        }

        .card-header {
            background: linear-gradient(100deg, var(--navy-mid) 0%, var(--blue) 100%);
            padding: 1.75rem 2rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .card-header-icon {
            width: 44px;
            height: 44px;
            background: rgba(255,255,255,0.15);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: white;
            flex-shrink: 0;
        }

        .card-header-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: white;
            margin-bottom: 0.15rem;
        }

        .card-header-sub {
            font-size: 0.78rem;
            color: rgba(255,255,255,0.6);
        }

        /* ── FORM BODY ── */
        .card-body {
            padding: 1.75rem 2rem;
        }

        /* 說明提示 */
        .info-strip {
            background: #e8f1fb;
            border: 1px solid #c5d9f0;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: flex-start;
            gap: 0.6rem;
            font-size: 0.82rem;
            color: var(--blue);
            line-height: 1.6;
        }

            .info-strip i {
                margin-top: 0.1rem;
                flex-shrink: 0;
            }

        /* 測試模式提示 */
        .test-strip {
            background: #fff8e1;
            border: 1px dashed var(--amber);
            border-radius: 8px;
            padding: 0.75rem 1rem;
            margin-bottom: 1.5rem;
            text-align: center;
        }

        .test-strip-label {
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--amber);
            letter-spacing: 0.05em;
            text-transform: uppercase;
            margin-bottom: 0.3rem;
        }

        .test-strip-code {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--navy);
            letter-spacing: 0.25em;
            font-variant-numeric: tabular-nums;
        }

        /* 錯誤訊息 */
        .alert-error {
            background: #fdecea;
            border: 1px solid #f5c6c2;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-size: 0.83rem;
            color: var(--danger);
            margin-bottom: 1.25rem;
            display: flex;
            align-items: flex-start;
            gap: 0.5rem;
        }

        /* OTP 輸入 */
        .otp-label {
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--text-sub);
            margin-bottom: 0.85rem;
            text-align: center;
        }

        .otp-inputs {
            display: flex;
            justify-content: center;
            gap: 0.6rem;
            margin-bottom: 1.25rem;
        }

        .otp-digit {
            width: 48px;
            height: 56px;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: 1.5rem;
            font-weight: 700;
            text-align: center;
            font-family: 'Courier New', monospace;
            color: var(--navy);
            background: var(--surface);
            transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
            outline: none;
        }

            .otp-digit:focus {
                border-color: var(--blue-lt);
                box-shadow: 0 0 0 3px rgba(37,137,216,0.12);
            }

            .otp-digit.filled {
                background: #f0f5fd;
                border-color: var(--blue);
            }

        /* 倒數計時 */
        .countdown {
            text-align: center;
            margin-bottom: 0.75rem;
        }

        .countdown-text {
            font-size: 0.8rem;
            color: var(--text-pale);
        }

        .countdown-time {
            font-size: 0.88rem;
            font-weight: 700;
            color: var(--danger);
            font-variant-numeric: tabular-nums;
        }

            .countdown-time.warn {
                color: var(--amber);
            }

            .countdown-time.ok {
                color: var(--text-sub);
            }

        .help-text {
            text-align: center;
            font-size: 0.78rem;
            color: var(--text-pale);
            margin-bottom: 1.5rem;
        }

        /* 按鈕 */
        .btn-row {
            display: flex;
            gap: 0.75rem;
            flex-direction: column;
        }

        .btn-submit {
            width: 100%;
            padding: 0.8rem;
            background: var(--navy);
            border: none;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 600;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            transition: background 0.15s;
            font-family: inherit;
            cursor: pointer;
        }

            .btn-submit:hover:not(:disabled) {
                background: var(--navy-mid);
            }

            .btn-submit:disabled {
                opacity: 0.45;
                cursor: not-allowed;
            }

        .btn-back {
            width: 100%;
            padding: 0.75rem;
            background: var(--surface);
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: 0.88rem;
            font-weight: 600;
            color: var(--text-sub);
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.35rem;
            transition: background 0.15s;
        }

            .btn-back:hover {
                background: var(--bg);
                text-decoration: none;
                color: var(--text-sub);
            }

        /* 底部 */
        .card-foot {
            padding: 1rem 2rem;
            border-top: 1px solid var(--border);
            background: var(--bg);
            font-size: 0.75rem;
            color: var(--text-pale);
            text-align: center;
            line-height: 1.6;
        }

        .resend-link {
            color: var(--blue);
            cursor: pointer;
            text-decoration: none;
            font-weight: 500;
        }

            .resend-link:hover {
                text-decoration: underline;
            }

        @@media (max-width: 600px) {
            .topbar {
                padding: 0 1rem;
            }

            .page-body {
                padding: 1.5rem 1rem;
            }

            .card-body {
                padding: 1.5rem 1.25rem;
            }

            .card-header {
                padding: 1.25rem;
            }

            .card-foot {
                padding: 0.85rem 1.25rem;
            }

            .otp-digit {
                width: 42px;
                height: 50px;
                font-size: 1.3rem;
            }

            .otp-inputs {
                gap: 0.45rem;
            }
        }
    </style>
</head>
<body>

    <!-- TOP BAR -->
    <header class="topbar">
        <div class="topbar-logo">
            <div class="cross">✚</div>
            代謝症候群疾病管理與追蹤系統
        </div>
        <div class="topbar-right">
            <a href="@Url.Action("Login", "Account")" class="topbar-back">
                <i class="bi bi-arrow-left"></i> 返回登入
            </a>
        </div>
    </header>

    <div class="page-body">
        <div class="form-card">

            <!-- 卡片頁首 -->
            <div class="card-header">
                <div class="card-header-icon">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <div>
                    <div class="card-header-title">輸入驗證碼</div>
                    <div class="card-header-sub">驗證碼已透過 LINE 發送，請在 5 分鐘內完成驗證</div>
                </div>
            </div>

            <!-- 表單主體 -->
            <div class="card-body">

                <!-- 說明 -->
                <div class="info-strip">
                    <i class="bi bi-chat-dots-fill"></i>
                    為確保帳號安全，首次登入需透過 LINE 驗證身分。請檢查您的 LINE 訊息取得驗證碼。
                </div>

                <!-- 測試模式驗證碼 -->
                @if (TempData["VerificationCode"] != null)
                {
                    <div class="test-strip">
                        <div class="test-strip-label">🧪 測試模式 — 驗證碼</div>
                        <div class="test-strip-code">@TempData["VerificationCode"]</div>
                    </div>
                }

                <!-- 錯誤訊息 -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-error">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        @Html.ValidationSummary(false)
                    </div>
                }

                <form asp-action="VerifyOtp" asp-controller="Account" method="post" id="otpForm">
                    @Html.AntiForgeryToken()

                    <div class="otp-label">請輸入 6 位數驗證碼</div>

                    <div class="otp-inputs">
                        <input type="text" class="otp-digit" maxlength="1" id="d0" data-index="0" inputmode="numeric" autocomplete="off" />
                        <input type="text" class="otp-digit" maxlength="1" id="d1" data-index="1" inputmode="numeric" autocomplete="off" />
                        <input type="text" class="otp-digit" maxlength="1" id="d2" data-index="2" inputmode="numeric" autocomplete="off" />
                        <input type="text" class="otp-digit" maxlength="1" id="d3" data-index="3" inputmode="numeric" autocomplete="off" />
                        <input type="text" class="otp-digit" maxlength="1" id="d4" data-index="4" inputmode="numeric" autocomplete="off" />
                        <input type="text" class="otp-digit" maxlength="1" id="d5" data-index="5" inputmode="numeric" autocomplete="off" />
                    </div>

                    <input type="hidden" name="otp" id="fullOtp" />

                    <div class="countdown">
                        <span class="countdown-text">驗證碼將在 </span>
                        <span class="countdown-time ok" id="timer">05:00</span>
                        <span class="countdown-text"> 後過期</span>
                    </div>

                    <div class="help-text">
                        <i class="bi bi-info-circle"></i> 請檢查您的 LINE 訊息
                    </div>

                    <div class="btn-row">
                        <button type="submit" class="btn-submit" id="submitBtn" disabled>
                            <i class="bi bi-check-lg"></i> 確認驗證
                        </button>
                        <a href="@Url.Action("Login", "Account")" class="btn-back">
                            <i class="bi bi-arrow-left"></i> 返回登入
                        </a>
                    </div>
                </form>
            </div>

            <!-- 底部 -->
            <div class="card-foot">
                沒有收到驗證碼？
                <span class="resend-link" onclick="resendOtp()">點此重新發送</span>
            </div>

        </div>
    </div>

    <script>
        const digits = document.querySelectorAll('.otp-digit');
        const fullOtp = document.getElementById('fullOtp');
        const submitBtn = document.getElementById('submitBtn');

        // 自動 focus 第一格
        digits[0].focus();

        digits.forEach((digit, index) => {
            digit.addEventListener('input', function () {
                this.value = this.value.replace(/[^0-9]/g, '');
                if (this.value.length === 1) {
                    this.classList.add('filled');
                    if (index < digits.length - 1) digits[index + 1].focus();
                    checkComplete();
                } else {
                    this.classList.remove('filled');
                    checkComplete();
                }
            });

            digit.addEventListener('keydown', function (e) {
                if (e.key === 'Backspace' && this.value === '' && index > 0) {
                    digits[index - 1].focus();
                    digits[index - 1].value = '';
                    digits[index - 1].classList.remove('filled');
                    checkComplete();
                }
            });

            digit.addEventListener('paste', function (e) {
                e.preventDefault();
                const paste = e.clipboardData.getData('text').replace(/[^0-9]/g, '');
                if (paste.length === 6) {
                    paste.split('').forEach((c, i) => {
                        digits[i].value = c;
                        digits[i].classList.add('filled');
                    });
                    checkComplete();
                    digits[5].focus();
                }
            });
        });

        function checkComplete() {
            const otp = Array.from(digits).map(d => d.value).join('');
            fullOtp.value = otp;
            submitBtn.disabled = otp.length !== 6;
        }

        // 倒數計時
        let timeLeft = 300;
        const timerEl = document.getElementById('timer');

        const countdownInterval = setInterval(() => {
            timeLeft--;
            const m = Math.floor(timeLeft / 60);
            const s = timeLeft % 60;
            timerEl.textContent = `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;

            if (timeLeft <= 60) {
                timerEl.className = 'countdown-time warn';
            } else {
                timerEl.className = 'countdown-time ok';
            }

            if (timeLeft <= 0) {
                clearInterval(countdownInterval);
                timerEl.className = 'countdown-time';
                timerEl.style.color = 'var(--danger)';
                alert('驗證碼已過期，請重新登入');
                window.location.href = '@Url.Action("Login", "Account")';
            }
        }, 1000);

        function resendOtp() {
            if (confirm('確定要重新發送驗證碼嗎？')) {
                window.location.href = '@Url.Action("Login", "Account")';
            }
        }
    </script>
</body>
</html>
